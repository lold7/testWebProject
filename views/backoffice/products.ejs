<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Product Management</title>
    <meta name="description" content="BookStore Admin Panel Product Management">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="admin-layout">
        <!-- ========== SIDEBAR ========== -->
        <aside class="admin-sidebar border-end bg-white">
            <div class="sidebar-header border-bottom">
                <div class="logo d-flex align-items-center gap-2">
                    <div class="logo-icon text-white"><i class="bi bi-book-half"></i></div>
                    <div>
                        <h5 class="m-0 fw-bold fs-6">BookStore</h5>
                        <small class="text-muted" style="font-size: 0.72rem;">Admin Panel</small>
                    </div>
                </div>
            </div>
            <div class="sidebar-nav mt-4">
                <ul class="nav flex-column gap-1 px-3">
                    <li class="nav-item">
                        <a href="/backoffice" class="nav-link"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/categories" class="nav-link"><i class="bi bi-diagram-3"></i> Category</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/products" class="nav-link active"><i class="bi bi-journal-check"></i> Product</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/inventory" class="nav-link"><i class="bi bi-box-seam"></i> Inventory</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/orders" class="nav-link"><i class="bi bi-receipt"></i> Orders</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/customers" class="nav-link"><i class="bi bi-people"></i> Customers</a>
                    </li>
                </ul>
            </div>
        </aside>

        <!-- ========== MAIN CONTENT ========== -->
        <main class="admin-main">
            <!-- Top Navbar -->
            <header class="admin-topbar bg-white border-bottom d-flex align-items-center justify-content-between px-4 sticky-top">
                <h4 class="m-0 fw-bold">Products</h4>
                <div class="d-flex align-items-center gap-4">
                    <div class="notification position-relative" style="cursor: pointer;">
                        <i class="bi bi-bell text-muted" style="font-size: 1.2rem;"></i>
                        <span class="position-absolute top-0 start-100 translate-middle p-1 bg-white border border-light rounded-circle" style="margin-top:2px; margin-left:-4px;">
                            <span class="d-block bg-primary rounded-circle" style="width:6px; height:6px;"></span>
                        </span>
                    </div>
                    <div class="user-profile d-flex flex-row align-items-center gap-3 border-start ps-4" style="cursor: pointer;">
                        <div class="text-end d-none d-md-block">
                            <h6 class="m-0 fw-bold font-size-14"><%= typeof user !== 'undefined' && user ? user.username : 'Admin' %></h6>
                            <small class="text-muted" style="font-size:0.75rem;">Store Manager</small>
                        </div>
                        <img src="<%= typeof user !== 'undefined' && user && user.avatar_url ? user.avatar_url : 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=150&auto=format&fit=crop' %>" alt="<%= typeof user !== 'undefined' && user ? user.username : 'Admin' %>" class="rounded-circle" width="40" height="40" style="object-fit:cover;">
                    </div>
                </div>
            </header>

            <!-- Dashboard Content Container -->
            <div class="p-4" style="max-width: 1400px;">

                <!-- Page Header & Actions -->
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                    <div>
                        <h2 class="fw-bold mb-1 fs-3">Product Management</h2>
                        <p class="text-muted m-0 font-size-14">Manage your bookstore inventory efficiently</p>
                    </div>
                    <div class="d-flex gap-3">
                        <button class="btn btn-white border rounded-3 fw-medium px-4 bg-white d-flex align-items-center gap-2 text-muted shadow-sm">
                            <i class="bi bi-download"></i> Export
                        </button>
                        <a href="/backoffice/inventory" class="btn btn-primary rounded-3 fw-medium px-4 d-flex align-items-center gap-2 shadow-sm">
                            <i class="bi bi-plus-lg"></i> Add New Product
                        </a>
                    </div>
                </div>

                <!-- Filter Bar -->
                <div class="admin-card py-2 px-3 mb-4 d-flex flex-wrap align-items-center justify-content-between gap-3 border-0">
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <form action="/backoffice/products" method="GET" class="d-flex align-items-center gap-2">
                            <select name="category" class="form-select form-select-sm rounded-pill border py-1 px-3 font-size-14 bg-white text-muted" onchange="this.form.submit()" style="width: auto;">
                                <option value="">All Categories</option>
                                <% if (typeof categories !== 'undefined' && categories) { %>
                                <% categories.forEach(function(cat) { %>
                                <option value="<%= cat.category_id %>" <%= typeof selectedCategory !== 'undefined' && selectedCategory == cat.category_id ? 'selected' : '' %>><%= cat.category_name %></option>
                                <% }); %>
                                <% } %>
                            </select>
                        </form>
                        <% if (typeof selectedCategory !== 'undefined' && selectedCategory) { %>
                        <a href="/backoffice/products" class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill py-2 px-3 fw-normal font-size-12 d-flex align-items-center gap-2 text-decoration-none">
                            Clear Filter <i class="bi bi-x text-primary fs-6 position-relative" style="cursor:pointer; top:1px;"></i>
                        </a>
                        <% } %>
                    </div>
                    <a href="/backoffice/products" class="btn btn-link text-muted p-0 ms-auto text-decoration-none border-0" aria-label="Refresh">
                        <i class="bi bi-arrow-clockwise fs-5"></i>
                    </a>
                </div>

                <!-- Table Container -->
                <div class="admin-card p-0 overflow-hidden border-0">
                    <div class="table-responsive">
                        <table class="table admin-table mb-0 align-middle table-hover">
                            <thead class="bg-white text-muted border-bottom">
                                <tr>
                                    <th class="ps-4 text-uppercase fw-semibold" style="letter-spacing: 0.05em;">Image</th>
                                    <th class="text-uppercase fw-semibold" style="letter-spacing: 0.05em;">Product Name</th>
                                    <th class="text-uppercase fw-semibold" style="letter-spacing: 0.05em;">Category</th>
                                    <th class="text-uppercase fw-semibold" style="letter-spacing: 0.05em;">Price</th>
                                    <th class="text-uppercase fw-semibold" style="letter-spacing: 0.05em;">Attributes</th>
                                    <th class="pe-4 text-end text-uppercase fw-semibold" style="letter-spacing: 0.05em;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof products !== 'undefined' && products && products.length > 0) { %>
                                <% products.forEach(function(p) { %>
                                <%
                                    var images = [];
                                    if (p.product_images) {
                                        if (typeof p.product_images === 'string') {
                                            try { images = JSON.parse(p.product_images); } catch(e) { images = [p.product_images]; }
                                        } else if (Array.isArray(p.product_images)) {
                                            images = p.product_images;
                                        }
                                    }
                                    var firstImage = images.length > 0 ? images[0] : '';
                                    var attrs = '';
                                    if (p.product_attributes) {
                                        var attrObj = typeof p.product_attributes === 'string' ? JSON.parse(p.product_attributes) : p.product_attributes;
                                        if (attrObj && attrObj.format) {
                                            attrs = Array.isArray(attrObj.format) ? attrObj.format.join(', ') : attrObj.format;
                                        }
                                    }
                                %>
                                <tr>
                                    <td class="ps-4">
                                        <div class="bg-light rounded p-2 d-flex align-items-center justify-content-center" style="width: 48px; height: 64px;">
                                            <% if (firstImage) { %>
                                            <img src="/images/products/<%= firstImage %>" alt="<%= p.product_name %>" class="img-fluid rounded shadow-sm" style="object-fit:cover; width: 100%; height: 100%;">
                                            <% } else { %>
                                            <i class="bi bi-image text-muted"></i>
                                            <% } %>
                                        </div>
                                    </td>
                                    <td>
                                        <h6 class="m-0 fw-bold font-size-14 mb-1"><%= p.product_name %></h6>
                                        <small class="text-muted" style="font-size:0.75rem;">ID: #<%= p.product_id %></small>
                                    </td>
                                    <td><span class="badge rounded-pill fw-normal" style="background-color: #e0f2fe; color: #0284c7; padding: 0.35rem 0.7rem;"><%= p.category_name || 'N/A' %></span></td>
                                    <td class="fw-medium text-dark">$<%= Number(p.product_price).toFixed(2) %></td>
                                    <td class="text-muted font-size-14"><%= attrs || '-' %></td>
                                    <td class="pe-4 text-end">
                                        <a href="/backoffice/inventory/<%= p.product_id %>" class="btn btn-link text-muted p-1 me-2 text-decoration-none"><i class="bi bi-pencil"></i></a>
                                        <form action="/backoffice/products/delete/<%= p.product_id %>" method="POST" style="display:inline;" onsubmit="return confirm('Delete this product?')">
                                            <button type="submit" class="btn btn-link text-muted p-1 text-decoration-none"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>
                                <% }); %>
                                <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">No products found.</td>
                                </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination Footer -->
                    <div class="d-flex flex-wrap align-items-center justify-content-between p-4 border-top bg-white">
                        <span class="text-muted font-size-14 mb-2 mb-md-0">Showing <strong><%= typeof products !== 'undefined' && products ? products.length : 0 %></strong> results</span>
                        <ul class="admin-pagination pagination m-0 gap-1 d-flex align-items-center">
                            <li class="page-item"><a class="page-link border-0 text-muted shadow-none bg-transparent" href="#"><i class="bi bi-chevron-left" style="font-size: 0.8rem;"></i></a></li>
                            <li class="page-item"><a class="page-link border-0 bg-primary text-white rounded-3 px-3 py-1 shadow-sm" href="#">1</a></li>
                            <li class="page-item"><a class="page-link border-0 text-muted bg-transparent px-3 py-1 shadow-none" href="#">2</a></li>
                            <li class="page-item"><a class="page-link border-0 text-muted bg-transparent px-3 py-1 shadow-none" href="#">3</a></li>
                            <li class="page-item disabled"><span class="page-link border-0 text-muted bg-transparent shadow-none">...</span></li>
                            <li class="page-item"><a class="page-link border-0 text-muted bg-transparent px-3 py-1 shadow-none" href="#">12</a></li>
                            <li class="page-item"><a class="page-link border-0 text-muted shadow-none bg-transparent" href="#"><i class="bi bi-chevron-right" style="font-size: 0.8rem;"></i></a></li>
                        </ul>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/backoffice.js"></script>
</body>
</html>
