<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard Overview</title>
    <meta name="description" content="BookStore Admin Panel Dashboard Overview">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="admin-layout">
        <!-- ========== SIDEBAR ========== -->
        <aside class="admin-sidebar border-end bg-white">
            <div class="sidebar-header border-bottom">
                <div class="logo d-flex align-items-center gap-2">
                    <div class="logo-icon text-white"><i class="bi bi-book-half"></i></div>
                    <div>
                        <h5 class="m-0 fw-bold fs-6">BookStore</h5>
                        <small class="text-muted" style="font-size: 0.72rem;">Admin Panel</small>
                    </div>
                </div>
            </div>
            <div class="sidebar-nav mt-4">
                <ul class="nav flex-column gap-1 px-3">
                    <li class="nav-item">
                        <a href="/backoffice" class="nav-link active"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/categories" class="nav-link"><i class="bi bi-diagram-3"></i> Category</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/products" class="nav-link"><i class="bi bi-journal-check"></i> Product</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/inventory" class="nav-link"><i class="bi bi-box-seam"></i> Inventory</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/orders" class="nav-link"><i class="bi bi-receipt"></i> Orders</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/customers" class="nav-link"><i class="bi bi-people"></i> Customers</a>
                    </li>
                </ul>
            </div>
        </aside>

        <!-- ========== MAIN CONTENT ========== -->
        <main class="admin-main">
            <!-- Top Navbar -->
            <header class="admin-topbar bg-white border-bottom d-flex align-items-center justify-content-between px-4 sticky-top">
                <h4 class="m-0 fw-bold">Overview</h4>
                <div class="d-flex align-items-center gap-4">
                    <div class="notification position-relative" style="cursor: pointer;">
                        <i class="bi bi-bell text-muted" style="font-size: 1.2rem;"></i>
                        <span class="position-absolute top-0 start-100 translate-middle p-1 bg-white border border-light rounded-circle" style="margin-top:2px; margin-left:-4px;">
                            <span class="d-block bg-primary rounded-circle" style="width:6px; height:6px;"></span>
                        </span>
                    </div>
                    <div class="user-profile d-flex flex-row align-items-center gap-3 border-start ps-4" style="cursor: pointer;">
                        <div class="text-end d-none d-md-block">
                            <h6 class="m-0 fw-bold font-size-14"><%= typeof user !== 'undefined' && user ? user.username : 'Admin' %></h6>
                            <small class="text-muted" style="font-size:0.75rem;">Store Manager</small>
                        </div>
                        <img src="<%= typeof user !== 'undefined' && user && user.avatar_url ? user.avatar_url : 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=150&auto=format&fit=crop' %>" alt="<%= typeof user !== 'undefined' && user ? user.username : 'Admin' %>" class="rounded-circle" width="40" height="40" style="object-fit:cover;">
                    </div>
                </div>
            </header>

            <!-- Dashboard Content Container -->
            <div class="p-4">

                <!-- KPI Cards -->
                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="admin-card">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="icon-box bg-primary-subtle text-primary"><i class="bi bi-book"></i></div>
                                <span class="badge bg-success-subtle text-success rounded-pill px-2 py-1"><i class="bi bi-arrow-up-right"></i> +12%</span>
                            </div>
                            <h6 class="text-muted fw-normal font-size-14 mb-1">Total Books</h6>
                            <h2 class="m-0 fw-bold"><%= typeof stats !== 'undefined' && stats.totalProducts ? stats.totalProducts : 0 %></h2>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="admin-card">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="icon-box bg-purple-subtle text-purple"><i class="bi bi-diagram-3"></i></div>
                                <span class="badge bg-success-subtle text-success rounded-pill px-2 py-1"><i class="bi bi-arrow-up-right"></i> +2%</span>
                            </div>
                            <h6 class="text-muted fw-normal font-size-14 mb-1">Total Orders</h6>
                            <h2 class="m-0 fw-bold"><%= typeof stats !== 'undefined' && stats.totalOrders ? stats.totalOrders : 0 %></h2>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="admin-card">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="icon-box bg-warning-subtle text-warning"><i class="bi bi-exclamation-triangle"></i></div>
                                <span class="badge bg-danger-subtle text-danger rounded-pill px-2 py-1"><i class="bi bi-arrow-up-right"></i> +5%</span>
                            </div>
                            <h6 class="text-muted fw-normal font-size-14 mb-1">Total Customers</h6>
                            <h2 class="m-0 fw-bold"><%= typeof stats !== 'undefined' && stats.totalCustomers ? stats.totalCustomers : 0 %></h2>
                        </div>
                    </div>
                </div>

                <!-- Table Card: Recent Inventory Updates -->
                <div class="admin-card mb-4 p-0 overflow-hidden">
                    <div class="d-flex justify-content-between align-items-center p-4 border-bottom border-light">
                        <h5 class="m-0 fw-bold fs-6">Recent Orders</h5>
                        <a href="#" class="text-primary text-decoration-none fw-semibold font-size-14">View All</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table admin-table mb-0 align-middle">
                            <thead class="bg-white text-muted">
                                <tr>
                                    <th class="ps-4 text-uppercase">Order</th>
                                    <th class="text-uppercase">Total</th>
                                    <th class="text-uppercase">Status</th>
                                    <th class="pe-4 text-end text-uppercase">Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof stats !== 'undefined' && stats.recentOrders && stats.recentOrders.length > 0) { %>
                                <% stats.recentOrders.forEach(function(order) { %>
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-3 py-1">
                                            <div class="book-color-block" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);"></div>
                                            <div>
                                                <h6 class="m-0 fw-semibold font-size-14">#<%= order.order_id %></h6>
                                                <small class="text-muted font-size-12"><%= order.username %></small>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-light text-dark border rounded-pill px-3 py-1 fw-normal">$<%= Number(order.total_price).toFixed(2) %></span></td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="font-size-14 fw-semibold"><%= order.status %></span>
                                        </div>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <span class="badge <%= order.status === 'completed' ? 'bg-success-subtle text-success' : order.status === 'cancelled' ? 'bg-danger-subtle text-danger' : 'bg-warning-subtle text-warning' %> rounded-pill px-3 py-2 fw-medium"><%= new Date(order.created_at).toLocaleDateString() %></span>
                                    </td>
                                </tr>
                                <% }); %>
                                <% } else { %>
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">No recent orders found.</td>
                                </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Bottom Action Cards -->
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="admin-card action-card h-100">
                            <div class="icon-circle mb-3">
                                <i class="bi bi-plus-lg"></i>
                            </div>
                            <h5 class="fw-bold mb-2">Add New Book</h5>
                            <p class="text-muted font-size-14 mb-4">Quickly add a new book to the inventory. Scan ISBN or enter details manually.</p>
                            <button class="btn btn-primary px-4 py-2 fw-medium rounded-3">Add Item</button>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="admin-card action-card-secondary h-100">
                            <div class="icon-circle mb-3">
                                <i class="bi bi-bar-chart-fill"></i>
                            </div>
                            <h5 class="fw-bold mb-2">Generate Report</h5>
                            <p class="text-muted font-size-14 mb-4">Download the monthly sales and inventory report for review.</p>
                            <button class="btn btn-outline-dark bg-white px-4 py-2 fw-medium rounded-3">Download PDF</button>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/backoffice.js"></script>
</body>
</html>
