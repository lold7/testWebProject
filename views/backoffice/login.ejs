<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login</title>
    <meta name="description" content="Sign in to your Bookstore Admin Panel">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-login-body">

    <div class="login-card mx-3 mx-sm-0">
        <div class="login-card-body">
            <div class="login-icon-box">
                <i class="bi bi-book-half"></i>
            </div>
            <h3 class="text-center fw-bold mb-2">Bookstore Admin</h3>
            <p class="text-center text-muted mb-4 font-size-14">Welcome back! Please sign in to continue.</p>

            <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <form action="/backoffice/login" method="POST">
                <div class="mb-3">
                    <label class="form-label fw-bold font-size-12 text-dark mb-2">Email Address</label>
                    <div class="position-relative">
                        <i class="bi bi-envelope login-input-icon"></i>
                        <input type="email" name="email" class="form-control login-form-control py-2 text-dark border-light-subtle shadow-sm" placeholder="admin@bookstore.com" required>
                    </div>
                </div>
                <div class="mb-3 mt-4">
                    <label class="form-label fw-bold font-size-12 text-dark mb-2">Password</label>
                    <div class="position-relative">
                        <i class="bi bi-lock login-input-icon"></i>
                        <input type="password" name="password" class="form-control login-form-control py-2 text-dark border-light-subtle shadow-sm" placeholder="Enter your password" required>
                    </div>
                </div>
                
                <div class="d-flex justify-content-end mb-4">
                    <a href="#" class="text-primary text-decoration-none font-size-12 fw-medium">Forgot Password?</a>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold shadow-sm">Sign In</button>
            </form>
        </div>
        <div class="login-card-footer">
            <p class="m-0 text-muted font-size-14 d-inline">Don't have an account? </p>
            <a href="#" class="text-primary text-decoration-none fw-medium font-size-14">Contact Support</a>
        </div>
    </div>

    <div class="mt-4 text-center">
        <p class="text-muted mb-0" style="font-size: 0.72rem;">&copy; 2024 Bookstore Inc. All rights reserved.</p>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/backoffice.js"></script>
</body>
</html>
