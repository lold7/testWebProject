<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Category Management</title>
    <meta name="description" content="Manage your bookstore categories">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="admin-layout">
        <!-- ========== SIDEBAR ========== -->
        <aside class="admin-sidebar border-end bg-white">
            <div class="sidebar-header border-bottom">
                <div class="logo d-flex align-items-center gap-2">
                    <div class="logo-icon text-white"><i class="bi bi-book-half"></i></div>
                    <div>
                        <h5 class="m-0 fw-bold fs-6">BookStore</h5>
                        <small class="text-muted" style="font-size: 0.72rem;">Admin Panel</small>
                    </div>
                </div>
            </div>
            <div class="sidebar-nav mt-4">
                <ul class="nav flex-column gap-1 px-3">
                    <li class="nav-item">
                        <a href="/backoffice" class="nav-link"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/categories" class="nav-link active"><i class="bi bi-diagram-3"></i> Category</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/products" class="nav-link"><i class="bi bi-journal-check"></i> Product</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/inventory" class="nav-link"><i class="bi bi-box-seam"></i> Inventory</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/orders" class="nav-link"><i class="bi bi-receipt"></i> Orders</a>
                    </li>
                    <li class="nav-item">
                        <a href="/backoffice/customers" class="nav-link"><i class="bi bi-people"></i> Customers</a>
                    </li>
                </ul>
            </div>
        </aside>

        <!-- ========== MAIN CONTENT ========== -->
        <main class="admin-main">
            <!-- Top Navbar -->
            <header class="admin-topbar bg-white border-bottom d-flex align-items-center justify-content-between px-4 sticky-top">
                <h4 class="m-0 fw-bold">Categories</h4>
                <div class="d-flex align-items-center gap-4">
                    <div class="notification position-relative" style="cursor: pointer;">
                        <i class="bi bi-bell text-muted" style="font-size: 1.2rem;"></i>
                        <span class="position-absolute top-0 start-100 translate-middle p-1 bg-white border border-light rounded-circle" style="margin-top:2px; margin-left:-4px;">
                            <span class="d-block bg-primary rounded-circle" style="width:6px; height:6px;"></span>
                        </span>
                    </div>
                    <div class="user-profile d-flex flex-row align-items-center gap-3 border-start ps-4" style="cursor: pointer;">
                        <div class="text-end d-none d-md-block">
                            <h6 class="m-0 fw-bold font-size-14"><%= typeof user !== 'undefined' && user ? user.username : 'Admin' %></h6>
                            <small class="text-muted" style="font-size:0.75rem;">Store Manager</small>
                        </div>
                        <img src="<%= typeof user !== 'undefined' && user && user.avatar_url ? user.avatar_url : 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=150&auto=format&fit=crop' %>" alt="<%= typeof user !== 'undefined' && user ? user.username : 'Admin' %>" class="rounded-circle" width="40" height="40" style="object-fit:cover;">
                    </div>
                </div>
            </header>

            <!-- Dashboard Content Container -->
            <div class="p-4" style="max-width: 1400px;">

                <!-- Page Header & Actions -->
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                    <div>
                        <h2 class="fw-bold mb-1 fs-3">Category Management</h2>
                        <p class="text-muted m-0 font-size-14">Organize your bookstore catalog structure</p>
                    </div>
                    <div class="d-flex gap-3">
                        <button class="btn btn-primary rounded-3 fw-medium px-4 d-flex align-items-center gap-2 shadow-sm" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
                            <i class="bi bi-plus-lg"></i> Add New Category
                        </button>
                    </div>
                </div>

                <!-- Table Container -->
                <div class="admin-card p-0 overflow-hidden border-0">
                    <div class="table-responsive">
                        <table class="table admin-table mb-0 align-middle table-hover">
                            <thead class="bg-white text-muted border-bottom">
                                <tr>
                                    <th class="ps-4 text-uppercase fw-semibold" style="letter-spacing: 0.05em; width: 60px;">#</th>
                                    <th class="text-uppercase fw-semibold" style="letter-spacing: 0.05em; width: 200px;">Category Name</th>
                                    <th class="text-uppercase fw-semibold" style="letter-spacing: 0.05em;">Description</th>
                                    <th class="text-uppercase fw-semibold" style="letter-spacing: 0.05em; width: 140px;">Total Books</th>
                                    <th class="text-uppercase fw-semibold" style="letter-spacing: 0.05em; width: 120px;">Status</th>
                                    <th class="pe-4 text-end text-uppercase fw-semibold" style="letter-spacing: 0.05em; width: 100px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
                                <% categories.forEach(function(category, index) { %>
                                <tr>
                                    <td class="ps-4 text-muted font-size-14"><%= index + 1 %></td>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="bg-primary-subtle text-primary rounded d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                                                <i class="bi bi-book"></i>
                                            </div>
                                            <h6 class="m-0 fw-bold font-size-14"><%= category.category_name %></h6>
                                        </div>
                                    </td>
                                    <td class="text-muted font-size-14 text-truncate" style="max-width: 350px;"><%= category.category_image || '' %></td>
                                    <td class="fw-medium text-dark"><%= category.product_count || 0 %></td>
                                    <td>
                                        <form action="/backoffice/categories/toggle/<%= category.category_id %>" method="POST" style="display:inline;">
                                            <button type="submit" class="badge <%= category.is_visible ? 'bg-success-subtle text-success border-success-subtle' : 'bg-danger-subtle text-danger border-danger-subtle' %> rounded-pill px-3 py-1 fw-normal border" style="cursor:pointer;">
                                                <%= category.is_visible ? 'Active' : 'Hidden' %>
                                            </button>
                                        </form>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <button class="btn btn-link text-muted p-1 me-2 text-decoration-none" title="Edit" data-bs-toggle="modal" data-bs-target="#editCategoryModal<%= category.category_id %>"><i class="bi bi-pencil"></i></button>
                                        <form action="/backoffice/categories/delete/<%= category.category_id %>" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this category?')">
                                            <button type="submit" class="btn btn-link text-danger p-1 text-decoration-none" title="Delete"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </td>
                                </tr>

                                <!-- Edit Modal for this category -->
                                <div class="modal fade" id="editCategoryModal<%= category.category_id %>" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <form action="/backoffice/categories/edit/<%= category.category_id %>" method="POST">
                                                <div class="modal-header">
                                                    <h5 class="modal-title fw-bold">Edit Category</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <div class="mb-3">
                                                        <label class="form-label fw-medium">Category Name</label>
                                                        <input type="text" name="category_name" class="form-control" value="<%= category.category_name %>" required>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label fw-medium">Category Image URL</label>
                                                        <input type="text" name="category_image" class="form-control" value="<%= category.category_image || '' %>">
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-white border" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-primary">Save Changes</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                                <% }); %>
                                <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">No categories found.</td>
                                </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div> <!-- End Table Container -->

            </div>
        </main>
    </div>

    <!-- Add Category Modal -->
    <div class="modal fade" id="addCategoryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/backoffice/categories/add" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold">Add New Category</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-medium">Category Name</label>
                            <input type="text" name="category_name" class="form-control" placeholder="Enter category name" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Category Image URL</label>
                            <input type="text" name="category_image" class="form-control" placeholder="Enter image URL (optional)">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-white border" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Add Category</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/backoffice.js"></script>
</body>
</html>