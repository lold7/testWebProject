<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Categories - InwZa Bookstore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm py-3">
        <div class="container d-flex align-items-center flex-wrap">

            <!-- Left: Logo on mobile (centered via CSS), Toggler on right -->
            <a class="navbar-brand d-lg-none mx-auto" href="/">
                <img src="/images/Logo.png" alt="InwZa Bookstore Logo" class="navbar-logo" width="100">
            </a>
            <button class="navbar-toggler border-0 position-absolute end-0 me-3 d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Desktop 3-column layout -->
            <div class="collapse navbar-collapse" id="mainNavbar">
                <!-- Left nav links -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 col-lg-4">
                    <li class="nav-item"><a class="nav-link fw-bold text-dark" href="/products">All Products</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="categoryDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Categories</a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="categoryDropdown">
                            <li><a class="dropdown-item" href="/category/fiction">Fiction</a></li>
                            <li><a class="dropdown-item" href="/category/nonfiction">Non-fiction</a></li>
                            <li><a class="dropdown-item" href="/category/children">Children\'s Books</a></li>
                            <li><a class="dropdown-item" href="/category/mystery">Mystery & Thriller</a></li>
                            <li><a class="dropdown-item" href="/category/science">Science & Tech</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-primary fw-bold" href="/categories">View All Categories</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">More</a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item" href="/contact">Contact</a></li>
                            <li><a class="dropdown-item" href="/account/profile">Account</a></li>
                            <li><a class="dropdown-item" href="/cart">Cart</a></li>
                        </ul>
                    </li>
                </ul>

                <!-- Center logo (desktop only) -->
                <div class="d-none d-lg-flex col-lg-4 justify-content-center">
                    <a class="navbar-brand m-0" href="/">
                        <img src="/images/Logo.png" alt="InwZa Bookstore Logo" class="navbar-logo" width="100">
                    </a>
                </div>

                <!-- Right: search + button -->
                <div class="d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center ms-lg-auto col-lg-4 justify-content-lg-end gap-2">
                    <form action="/search" method="GET" class="d-flex position-relative my-2 my-lg-0">
                        <input name="q" class="form-control rounded-pill pe-5 bg-light border-0 w-100" type="search" placeholder="Search products..." aria-label="Search">
                        <i class="bi bi-search position-absolute top-50 end-0 translate-middle-y me-3 text-muted"></i>
                    </form>
                    <a href="/cart" class="btn btn-outline-dark rounded-pill px-3 mt-2 mt-lg-0 position-relative"><i class="bi bi-cart3 fs-5"></i><% if (cartCount > 0) { %><span class="cart-badge badge bg-primary rounded-pill position-absolute" style="font-size:0.6rem;top:-5px;right:-5px;"><%= cartCount %></span><% } %></a>
                    <% if (user) { %>
                    <div class="dropdown mt-2 mt-lg-0">
                        <a class="btn btn-primary rounded-pill px-4 dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"><%= user.username %></a>
                        <ul class="dropdown-menu border-0 shadow">
                            <li><a class="dropdown-item" href="/account/profile">Profile</a></li>
                            <li><a class="dropdown-item" href="/account/orders">Order History</a></li>
                            <li><a class="dropdown-item" href="/account/wishlist">Wishlist</a></li>
                            <li><a class="dropdown-item" href="/account/addresses">Address Book</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/auth/logout">Logout</a></li>
                        </ul>
                    </div>
                    <% } else { %>
                    <a href="/auth/login" class="btn btn-primary rounded-pill px-4 mt-2 mt-lg-0">Login</a>
                    <% } %>
                </div>
            </div>

        </div>
    </nav>

    <section class="container mt-5 pt-4 text-center">
        <h1 class="display-4 fw-bold mb-3">Shop by category</h1>
        <p class="text-muted">Browse our curated collection of books by category. Find your next great read.</p>
    </section>

    <section class="container my-5 py-4">
        <div class="text-center mb-5">
            <span class="text-muted text-uppercase small fw-bold">Browse</span>
            <h2 class="fw-bold">Explore our collection</h2>
            <p class="text-muted small">Find the perfect book in every genre we offer.</p>
        </div>

        <%
            // Build a URL slug mapping from category name
            function getCategorySlug(name) {
                const map = {
                    'Fiction': 'fiction',
                    'Children': 'children',
                    'Non-Fiction': 'nonfiction',
                    'Mystery & Thriller': 'mystery',
                    'Science & Technology': 'science'
                };
                return map[name] || name.toLowerCase().replace(/[^a-z0-9]+/g, '-');
            }
            // Default images for categories
            const defaultImages = {
                'Fiction': 'https://9kafe.com/wp-content/uploads/2024/08/lord-of-the-mysteries-wn.jpg',
                'Non-Fiction': 'https://images.unsplash.com/photo-1589998059171-988d887df646?q=80&w=800&auto=format&fit=crop',
                'Children': 'https://m.media-amazon.com/images/I/91Rd6IjcSWL._AC_UF1000,1000_QL80_.jpg',
                'Mystery & Thriller': 'https://images.unsplash.com/photo-1618666012174-83b441c0bc76?q=80&w=800&auto=format&fit=crop',
                'Science & Technology': 'https://images.unsplash.com/photo-1532094349884-543bc11b234d?q=80&w=800&auto=format&fit=crop'
            };
            const defaultDescs = {
                'Fiction': 'Stories that transport you to other worlds.',
                'Non-Fiction': 'Real stories and ideas that shape how we think.',
                'Children': 'Young adult and coming-of-age tales for every reader',
                'Mystery & Thriller': 'Dark vibes and unexpected twists keep you guessing until the end.',
                'Science & Technology': 'Explore how ideas shape the world in our grid system and discovery.'
            };
            // Find categories by name or use index
            const fiction = categories.find(c => c.category_name === 'Fiction');
            const nonfiction = categories.find(c => c.category_name === 'Non-Fiction');
            const children = categories.find(c => c.category_name === 'Children');
            const mystery = categories.find(c => c.category_name === 'Mystery & Thriller');
            const science = categories.find(c => c.category_name === 'Science & Technology');
        %>
        <div class="row g-4">
            <div class="col-lg-4 d-flex flex-column gap-4">
                <% if (fiction) { %>
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative category-card">
                    <img src="<%= fiction.category_image || defaultImages['Fiction'] %>" class="w-100 h-100" style="object-fit: cover;" alt="<%= fiction.category_name %>">

                    <div class="card-img-overlay d-flex flex-column justify-content-end p-4" style="background: linear-gradient(to top, rgba(0,0,0,0.85), rgba(0,0,0,0) 60%);">
                        <h4 class="fw-bold text-white mb-1"><%= fiction.category_name %></h4>
                        <p class="text-white-50 small mb-3"><%= defaultDescs['Fiction'] %></p>
                        <a href="/category/<%= getCategorySlug(fiction.category_name) %>" class="text-white fw-bold text-decoration-none mt-auto Explore-link">Browse <i class="bi bi-chevron-right small"></i></a>
                    </div>
                </div>
                <% } %>

                <% if (nonfiction) { %>
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 position-relative category-card">
                    <img src="<%= nonfiction.category_image || defaultImages['Non-Fiction'] %>" class="w-100 h-100" style="object-fit: cover;" alt="<%= nonfiction.category_name %>">

                    <div class="card-img-overlay d-flex flex-column justify-content-end p-4" style="background: linear-gradient(to top, rgba(0,0,0,0.85), rgba(0,0,0,0) 60%);">
                        <h4 class="fw-bold text-white mb-1"><%= nonfiction.category_name %></h4>
                        <p class="text-white-50 small mb-3"><%= defaultDescs['Non-Fiction'] %></p>
                        <a href="/category/<%= getCategorySlug(nonfiction.category_name) %>" class="text-white fw-bold text-decoration-none mt-auto Explore-link">Browse <i class="bi bi-chevron-right small"></i></a>
                    </div>
                </div>
                <% } %>
            </div>

            <div class="col-lg-8">
                <% if (children) { %>
                <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden" style="background-color: #e9ecef;">
                    <div class="row g-0 h-100">
                        <div class="col-md-6 p-5 d-flex flex-column justify-content-center">
                            <span class="text-muted small fw-bold mb-2"><%= children.category_name %>'s</span>
                            <h2 class="fw-bold mb-4"><%= defaultDescs['Children'] %></h2>
                            <a href="/category/<%= getCategorySlug(children.category_name) %>" class="text-dark fw-bold text-decoration-none mt-3">Browse <i class="bi bi-chevron-right small"></i></a>
                        </div>
                        <div class="col-md-6">
                            <img src="<%= children.category_image || defaultImages['Children'] %>" class="img-fluid h-100 w-100" alt="<%= children.category_name %>" style="object-fit: cover;">
                        </div>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </section>

    <section class="container my-5 py-4">
        <div class="text-center mb-5">
            <span class="text-muted text-uppercase small fw-bold">Discover</span>
            <h2 class="fw-bold">Deep dives into mystery</h2>
            <p class="text-muted small">Unravel secrets and solve puzzles with every turn of the page.</p>
        </div>

        <div class="row g-4">
            <% if (mystery) { %>
            <div class="col-md-6">
                <div class="card border-0">
                    <img src="<%= mystery.category_image || defaultImages['Mystery & Thriller'] %>" class="card-img-top rounded-4 mb-3" alt="<%= mystery.category_name %>" style="height: 250px; object-fit: cover;">
                    <div class="card-body px-0">
                        <h4 class="fw-bold">Mystery and thriller</h4>
                        <p class="text-muted small mb-3"><%= defaultDescs['Mystery & Thriller'] %></p>
                        <div class="d-flex gap-2 mb-3">
                            <span class="badge bg-light text-dark border">Mystery</span>
                            <span class="badge bg-light text-dark border">Thriller</span>
                            <span class="badge bg-light text-dark border">Suspense</span>
                        </div>
                        <a href="/category/<%= getCategorySlug(mystery.category_name) %>" class="text-dark fw-bold text-decoration-none">Browse <i class="bi bi-chevron-right small"></i></a>
                    </div>
                </div>
            </div>
            <% } %>
            <% if (science) { %>
            <div class="col-md-6">
                <div class="card border-0">
                    <img src="<%= science.category_image || defaultImages['Science & Technology'] %>" class="card-img-top rounded-4 mb-3" alt="<%= science.category_name %>" style="height: 250px; object-fit: cover;">
                    <div class="card-body px-0">
                        <h4 class="fw-bold">Science and technology</h4>
                        <p class="text-muted small mb-3"><%= defaultDescs['Science & Technology'] %></p>
                        <div class="d-flex gap-2 mb-3">
                            <span class="badge bg-light text-dark border">Science</span>
                            <span class="badge bg-light text-dark border">Technology</span>
                            <span class="badge bg-light text-dark border">Innovation</span>
                        </div>
                        <a href="/category/<%= getCategorySlug(science.category_name) %>" class="text-dark fw-bold text-decoration-none">Browse <i class="bi bi-chevron-right small"></i></a>
                    </div>
                </div>
            </div>
            <% } %>
        </div>
    </section>

    <section class="container my-5 pb-5">
        <div class="card border-0 rounded-4 overflow-hidden text-center text-white d-flex align-items-center justify-content-center py-5" style="background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('https://images.unsplash.com/photo-1507842217343-583bb7270b66?q=80&w=1600&auto=format&fit=crop') center/cover; min-height: 250px;">
            <div class="position-relative z-1">
                <h2 class="fw-bold mb-3">Start your next adventure</h2>
                <p class="mb-4">Dive into a new genre and discover stories that matter to you today.</p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="/products" class="btn btn-primary rounded-pill px-4">Explore</a>
                    <a href="/categories" class="btn btn-outline-light rounded-pill px-4 text-white border-white">Browse</a>
                </div>
            </div>
        </div>
    </section>

    <footer class="container py-5 border-top">
        <div class="row">
            <div class="col-12 col-md-4 mb-4">
                <img src="/images/Logo.png" alt="Logo" width="80" class="mb-3 rounded">
                <p class="text-muted small">Address:<br>Level 2, 45 King Street, Sydney NSW 2000</p>
                <p class="text-muted small">Contact:<br>1800 555 123<br><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="fe969b929291be979089849f9c9191958d8a918c9bd09d9193">[email&#160;protected]</a></p>
                <div class="d-flex gap-3 mt-3">
                    <a href="#" class="text-dark"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="text-dark"><i class="bi bi-twitter"></i></a>
                    <a href="#" class="text-dark"><i class="bi bi-instagram"></i></a>
                </div>
            </div>
            <div class="col-6 col-md-4 mb-4">
                <ul class="list-unstyled text-muted small lh-lg">
                    <li><a href="/products" class="text-decoration-none text-muted">All products</a></li>
                    <li><a href="/categories" class="text-decoration-none text-muted">Categories</a></li>
                    <li><a href="/contact" class="text-decoration-none text-muted">Contact us</a></li>
                </ul>
            </div>
            <div class="col-6 col-md-4 mb-4">
                <ul class="list-unstyled text-muted small lh-lg">
                    <li><a href="/account/profile" class="text-decoration-none text-muted">Account</a></li>
                    <li><a href="/cart" class="text-decoration-none text-muted">Cart</a></li>
                    <li><a href="/faq" class="text-decoration-none text-muted">FAQ</a></li>
                </ul>
            </div>
        </div>
        <div class="d-flex justify-content-between pt-4 mt-4 border-top text-muted small">
            <p>&copy; 2026 InwZa Bookstore. All rights reserved.</p>
            <div class="d-flex gap-3">
                <a href="/condition" class="text-decoration-none text-muted">Privacy policy</a>
                <a href="/condition" class="text-decoration-none text-muted">Terms of service</a>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/cart.js"></script>
    <script src="/js/wishlist.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>