<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Children's Books - InwZa Bookstore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body class="bg-white">

    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm py-3">
        <div class="container d-flex align-items-center flex-wrap">
            <a class="navbar-brand d-lg-none mx-auto" href="/">
                <img src="/images/Logo.png" alt="Logo" class="navbar-logo" width="100">
            </a>
            <button class="navbar-toggler border-0 position-absolute end-0 me-3 d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 col-lg-4">
                    <li class="nav-item"><a class="nav-link fw-bold text-dark" href="/products">All Products</a></li>
                    
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-primary" href="#" id="categoryDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Categories
                        </a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="categoryDropdown">
                            <li><a class="dropdown-item" href="/category/fiction">Fiction</a></li>
                            <li><a class="dropdown-item" href="/category/nonfiction">Non-fiction</a></li>
                            <li><a class="dropdown-item fw-bold" href="/category/children">Children's Books</a></li>
                            <li><a class="dropdown-item" href="/category/mystery">Mystery & Thriller</a></li>
                            <li><a class="dropdown-item" href="/category/science">Science & Tech</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-primary" href="/categories">View All Categories</a></li>
                        </ul>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">More</a>
                        <ul class="dropdown-menu border-0 shadow">
                            <li><a class="dropdown-item" href="/contact">Contact</a></li>
                            <li><a class="dropdown-item" href="/account/profile">Account</a></li>
                            <li><a class="dropdown-item" href="/cart">Cart</a></li>
                        </ul>
                    </li>
                </ul>

                <div class="d-none d-lg-flex col-lg-4 justify-content-center">
                    <a class="navbar-brand m-0" href="/">
                        <img src="/images/Logo.png" alt="Logo" class="navbar-logo" width="100">
                    </a>
                </div>

                <div class="d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center ms-lg-auto col-lg-4 justify-content-lg-end gap-2">
                    <form action="/search" method="GET" class="d-flex position-relative my-2 my-lg-0">
                        <input name="q" class="form-control rounded-pill pe-5 bg-light border-0 w-100" type="search" placeholder="Search products...">
                        <button type="submit" class="btn position-absolute top-50 end-0 translate-middle-y border-0 p-0 me-3">
                            <i class="bi bi-search text-muted"></i>
                        </button>
                    </form>
                    <a href="/cart" class="btn btn-outline-dark rounded-pill px-3 mt-2 mt-lg-0 position-relative"><i class="bi bi-cart3 fs-5"></i><span class="cart-badge badge bg-primary rounded-pill position-absolute" style="<%= (typeof cartCount !== 'undefined' && cartCount > 0) ? '' : 'display:none;' %>font-size:0.6rem;top:-5px;right:-5px;"><%= (typeof cartCount !== 'undefined') ? cartCount : 0 %></span></a>
                    <% if (typeof user !== 'undefined' && user) { %>
                    <div class="dropdown mt-2 mt-lg-0">
                        <a class="btn btn-primary rounded-pill px-4 dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"><%= user.username %></a>
                        <ul class="dropdown-menu border-0 shadow">
                            <li><a class="dropdown-item" href="/account/profile">Profile</a></li>
                            <li><a class="dropdown-item" href="/account/orders">Order History</a></li>
                            <li><a class="dropdown-item" href="/account/wishlist">Wishlist</a></li>
                            <li><a class="dropdown-item" href="/account/addresses">Address Book</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/auth/logout">Logout</a></li>
                        </ul>
                    </div>
                    <% } else { %>
                    <a href="/auth/login" class="btn btn-primary rounded-pill px-4 mt-2 mt-lg-0">Login</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <section class="container mt-5 pt-5 text-center">
        <h1 class="display-4 fw-bold mb-3">Children's books and young adult</h1>
        <p class="text-muted">Explore our curated collection of picture books, fairy tales, and coming-of-age stories.</p>
    </section>

    <section class="container my-5 py-4">
        <div class="text-center mb-5">
            <span class="text-muted text-uppercase small fw-bold">Curated</span>
            <h2 class="fw-bold">Recommend Books</h2>
            <p class="text-muted small">Discover the best in children's literature today.</p>
        </div>

        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="card border-0 bg-light rounded-4 p-3 d-flex flex-row align-items-center h-100 feature-mini-card">
                    <img src="https://m.media-amazon.com/images/I/61qxa9zrFOL._AC_UF894,1000_QL80_.jpg" class="rounded-3" alt="Award" style="width: 100px; height: 100px; object-fit: cover;">
                    <div class="ms-3">
                        <span class="text-muted small fw-bold">Featured</span>
                        <h6 class="fw-bold mb-1">Award-winning titles</h6>
                        <a href="#" class="text-dark small text-decoration-none fw-bold">View <i class="bi bi-chevron-right"></i></a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-light rounded-4 p-3 d-flex flex-row align-items-center h-100 feature-mini-card">
                    <img src="https://m.media-amazon.com/images/I/61qxa9zrFOL._AC_UF894,1000_QL80_.jpg" class="rounded-3" alt="Staff Picks" style="width: 100px; height: 100px; object-fit: cover;">
                    <div class="ms-3">
                        <span class="text-muted small fw-bold">Curated</span>
                        <h6 class="fw-bold mb-1">Staff picks</h6>
                        <a href="#" class="text-dark small text-decoration-none fw-bold">View <i class="bi bi-chevron-right"></i></a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 bg-light rounded-4 p-3 d-flex flex-row align-items-center h-100 feature-mini-card">
                    <img src="https://m.media-amazon.com/images/I/61qxa9zrFOL._AC_UF894,1000_QL80_.jpg" class="rounded-3" alt="Top Rated" style="width: 100px; height: 100px; object-fit: cover;">
                    <div class="ms-3">
                        <span class="text-muted small fw-bold">Readers</span>
                        <h6 class="fw-bold mb-1">Top rated by readers</h6>
                        <a href="#" class="text-dark small text-decoration-none fw-bold">View <i class="bi bi-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="container my-5">
        <div class="text-center mb-4">
            <span class="text-muted text-uppercase small fw-bold">Featured</span>
            <h2 class="fw-bold">Books</h2>
            <p class="text-muted small">Our highlight pick of the month.</p>
        </div>
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-light">
            <div class="row g-0 align-items-center">
                <div class="col-md-7">
                    <img src="https://m.media-amazon.com/images/I/61qxa9zrFOL._AC_UF894,1000_QL80_.jpg" class="img-fluid w-100" alt="Europe War" style="object-fit: cover; height: 550px;">
                </div>
                <div class="col-md-5 p-5">
                    <span class="badge bg-dark text-white mb-2">Historical Fiction</span>
                    <h2 class="fw-bold mb-3">Europe War</h2>
                    <p class="text-muted mb-4">A novel of loss and redemption in post-war Europe. Discover the gripping tale that everyone is talking about.</p>
                    <a href="/product/1" class="btn btn-primary rounded-pill px-4">Details</a>
                    <a href="#" class="btn btn-outline-dark rounded-pill px-4 ms-2">Add to cart</a>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-light-blue py-5 mt-5">
        <div class="container py-4">
            <div class="text-center mb-5">
                <span class="text-muted text-uppercase small fw-bold">Collection</span>
                <h2 class="fw-bold">Books</h2>
                <p class="text-muted small">Dive into our collection of the best children's books.</p>
            </div>

            <div class="row g-4 justify-content-center" id="book-collection">

                <% products.forEach(function(product) { %>
                <% const images = typeof product.product_images === 'string' ? JSON.parse(product.product_images) : product.product_images; %>
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="card border-0 h-100 bg-transparent text-center book-card-hover" data-product-id="<%= product.product_id %>" style="cursor:pointer;">
                        <img src="/images/products/<%= images && images[0] ? images[0] : 'children-01.png' %>" class="card-img-top rounded-4 shadow-sm mb-3" alt="<%= product.product_name %>" style="height: 320px; object-fit: cover;">
                        <h6 class="fw-bold mb-1"><%= product.product_name %></h6>
                        <p class="text-muted small mb-1"><%= product.author || 'Unknown Author' %></p>
                        <p class="fw-bold">$<%= parseFloat(p.product_price).toFixed(2) %></p>
                    </div>
                </div>
                <% }); %>

            </div>

            <nav class="mt-4"><ul id="pagination-controls" class="pagination justify-content-center"></ul></nav>
            <div class="text-center mt-5">
                <a href="/products" class="btn btn-light bg-white border rounded-pill px-4 fw-bold shadow-sm">View all children's books</a>
            </div>
        </div>
    </section>

    <section class="container my-5 pb-5">
        <div class="card border-0 rounded-4 overflow-hidden text-center text-white d-flex align-items-center justify-content-center py-5" style="background: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('https://images.unsplash.com/photo-1507842217343-583bb7270b66?q=80&w=1600&auto=format&fit=crop') center/cover; min-height: 200px;">
            <div class="position-relative z-1">
                <h2 class="fw-bold mb-3">Stories that spark young imaginations</h2>
                <p class="mb-4">Find your next great read with our special offers.</p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="/auth/login" class="btn btn-primary rounded-pill px-4">Sign in</a>
                    <a href="/products" class="btn btn-outline-light rounded-pill px-4 text-white border-white">Shop now</a>
                </div>
            </div>
        </div>
    </section>

    <footer class="container py-5 border-top">
        <div class="text-center text-muted small pt-4 mt-4 border-top">
            <p>&copy; 2026 InwZa Bookstore. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/cart.js"></script>
    <script src="/js/wishlist.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/pagination.js"></script>
</body>
</html>