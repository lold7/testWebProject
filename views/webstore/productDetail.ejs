<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.product_name %> - InwZa Bookstore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body class="bg-white">

    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm py-3">
        <div class="container d-flex align-items-center">
            <div class="col-lg-4 collapse navbar-collapse d-none d-lg-flex" id="navbarNavLeft">
                <ul class="navbar-nav mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link fw-bold text-dark" href="/products">All Products</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="categoryDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Categories</a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="categoryDropdown">
                            <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                                <% categories.forEach(cat => { %>
                                    <% const slug = cat.category_name.toLowerCase().replace(/[^a-z0-9]+/g, '').replace('fiction','fiction').replace('nonfiction','nonfiction').replace('children','children').replace('mystery','mystery').replace('science','science'); %>
                                    <% const slugMap = { 'Fiction': 'fiction', 'Non-Fiction': 'nonfiction', "Children": 'children', "Mystery & Thriller": 'mystery', "Science & Technology": 'science' }; %>
                                    <li><a class="dropdown-item" href="/category/<%= slugMap[cat.category_name] || cat.category_name.toLowerCase().replace(/[^a-z]+/g, '') %>"><%= cat.category_name %></a></li>
                                <% }); %>
                            <% } else { %>
                            <li><a class="dropdown-item" href="/category/fiction">Fiction</a></li>
                            <li><a class="dropdown-item" href="/category/nonfiction">Non-fiction</a></li>
                            <li><a class="dropdown-item" href="/category/children">Children's Books</a></li>
                            <li><a class="dropdown-item" href="/category/mystery">Mystery & Thriller</a></li>
                            <li><a class="dropdown-item" href="/category/science">Science & Tech</a></li>
                            <% } %>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-primary fw-bold" href="/categories">View All Categories</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">More</a>
                        <ul class="dropdown-menu border-0 shadow">
                            <li><a class="dropdown-item" href="/contact">Contact</a></li>
                            <li><a class="dropdown-item" href="/account/profile">Account</a></li>
                            <li><a class="dropdown-item" href="/cart">Cart</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
            <div class="col-6 col-lg-4 text-center mx-auto mx-lg-0">
                <a class="navbar-brand" href="/">
                   <img src="/images/Logo.png" alt="InwZa Bookstore Logo" class="navbar-logo" width="100">
                </a>
            </div>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavLeft, #navbarNavRight">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="col-lg-4 collapse navbar-collapse justify-content-end" id="navbarNavRight">
                <form action="/search" method="GET" class="d-flex position-relative me-3 mt-3 mt-lg-0">
                    <input name="q" class="form-control rounded-pill pe-5 bg-light border-0" type="search" placeholder="Search products..." aria-label="Search" style="width: 250px;" required>
                    <button type="submit" class="btn position-absolute top-50 end-0 translate-middle-y border-0 p-0 me-3">
                        <i class="bi bi-search text-muted"></i>
                    </button>
                </form>
                <a href="/cart" class="btn btn-outline-dark rounded-pill px-3 mt-2 mt-lg-0 position-relative"><i class="bi bi-cart3 fs-5"></i><span class="cart-badge badge bg-primary rounded-pill position-absolute" style="display:none;font-size:0.6rem;top:-5px;right:-5px;"><%= typeof cartCount !== 'undefined' ? cartCount : 0 %></span></a>
                    <% if (typeof user !== 'undefined' && user) { %>
                        <div class="dropdown mt-2 mt-lg-0">
                            <a class="btn btn-outline-dark rounded-pill px-4 dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i> <%= user.username %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                                <li><a class="dropdown-item" href="/account/profile">Profile</a></li>
                                <li><a class="dropdown-item" href="/account/orders">Order History</a></li>
                                <li><a class="dropdown-item" href="/account/wishlist">Wishlist</a></li>
                                <li><a class="dropdown-item" href="/account/addresses">Address Book</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="/auth/logout">Logout</a></li>
                            </ul>
                        </div>
                    <% } else { %>
                    <a href="/auth/login" class="btn btn-primary rounded-pill px-4 mt-2 mt-lg-0">Login</a>
                    <% } %>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb small">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Home</a></li>
                <li class="breadcrumb-item"><a href="/categories" class="text-decoration-none text-muted">Categories</a></li>
                <% if (product.category_name) { %>
                <li class="breadcrumb-item"><a href="/categories" class="text-decoration-none text-muted"><%= product.category_name %></a></li>
                <% } %>
                <li class="breadcrumb-item active fw-bold text-dark" aria-current="page"><%= product.product_name %></li>
            </ol>
        </nav>
    </div>

    <section class="container my-4 pb-5">
        <div class="row g-5 justify-content-center">
            
            <% const images = typeof product.product_images === 'string' ? JSON.parse(product.product_images) : (product.product_images || []); %>
            <div class="col-md-5">
                <div class="card border-0 rounded-4 overflow-hidden shadow-sm">
                    <img src="/images/products/<%= images.length > 0 ? images[0] : 'placeholder.png' %>" class="img-fluid w-100" alt="<%= product.product_name %>" style="object-fit: cover; height: 600px;">
                </div>
            </div>

            <div class="col-md-6 d-flex flex-column">
                <div class="mb-4">
                    <span class="badge bg-light text-dark border mb-2"><%= product.category_name || 'Book' %></span>
                    <h1 class="display-5 fw-bold mb-2"><%= product.product_name %></h1>
                    <p class="text-muted fs-5 mb-3">By <%= product.author || 'Unknown Author' %></p>
                    <h2 class="fw-bold text-primary mb-4">$<%= parseFloat(product.product_price).toFixed(2) %></h2>
                    <p class="text-muted" style="line-height: 1.8;">
                        <%= product.product_description %>
                    </p>
                </div>

                <% const attrs = typeof product.product_attributes === 'string' ? JSON.parse(product.product_attributes) : (product.product_attributes || {}); %>
                <% if (attrs.format && attrs.format.length > 0) { %>
                <div class="mb-4">
                    <label class="form-label fw-bold small">Format</label>
                    <select id="product-format" name="selected_format" class="form-select bg-light border-0 rounded-3 py-2 w-50">
                        <% attrs.format.forEach((fmt, i) => { %>
                        <option value="<%= fmt.toLowerCase() %>" <%= i === 0 ? 'selected' : '' %>><%= fmt %></option>
                        <% }); %>
                    </select>
                </div>
                <% } %>

                <form action="/cart/add" method="POST" class="d-flex align-items-center gap-3 mt-auto pt-4 border-top">
                    <input type="hidden" name="product_id" value="<%= product.product_id %>">
                    <div class="input-group w-auto">
                        <button class="btn btn-light border btn-qty-minus" type="button"><i class="bi bi-dash"></i></button>
                        <input id="product-qty" name="quantity" type="number" class="form-control text-center bg-white border" value="1" min="1" max="10" style="max-width: 60px;" readonly>
                        <button class="btn btn-light border btn-qty-plus" type="button"><i class="bi bi-plus"></i></button>
                    </div>

                    <button id="btn-add-to-cart" type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold flex-grow-1">
                        <i class="bi bi-cart-plus me-2"></i> Add to Cart
                    </button>
                    <button id="btn-wishlist" type="button" class="btn btn-outline-dark rounded-pill px-3 py-2" data-product-id="<%= product.product_id %>"><i class="bi bi-heart<%= (typeof isWishlisted !== 'undefined' && isWishlisted) ? '-fill' : '' %>"></i></button>
                </form>
                
                <div class="mt-4 text-muted small">
                    <p class="mb-1"><i class="bi bi-truck me-2"></i> Free shipping on orders over $50</p>
                    <p class="mb-0"><i class="bi bi-arrow-return-left me-2"></i> 30-day return policy</p>
                </div>
            </div>
            
        </div>
    </section>

    <footer class="container py-5 border-top bg-light">
        <div class="text-center text-muted small pt-4 mt-4 border-top">
            <p>&copy; 2026 InwZa Bookstore. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/cart.js"></script>
    <script src="/js/wishlist.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>