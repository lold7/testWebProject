<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Products - InwZa Bookstore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm py-3">
        <div class="container d-flex align-items-center flex-wrap">

            <!-- Left: Logo on mobile (centered via CSS), Toggler on right -->
            <a class="navbar-brand d-lg-none mx-auto" href="/">
                <img src="/images/Logo.png" alt="InwZa Bookstore Logo" class="navbar-logo" width="100">
            </a>
            <button class="navbar-toggler border-0 position-absolute end-0 me-3 d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Desktop 3-column layout -->
            <div class="collapse navbar-collapse" id="mainNavbar">
                <!-- Left nav links -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 col-lg-4">
                    <li class="nav-item"><a class="nav-link fw-bold text-dark" href="/products">All Products</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="categoryDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Categories</a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="categoryDropdown">
                            <li><a class="dropdown-item" href="/category/fiction">Fiction</a></li>
                            <li><a class="dropdown-item" href="/category/nonfiction">Non-fiction</a></li>
                            <li><a class="dropdown-item" href="/category/children">Children\'s Books</a></li>
                            <li><a class="dropdown-item" href="/category/mystery">Mystery & Thriller</a></li>
                            <li><a class="dropdown-item" href="/category/science">Science & Tech</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-primary fw-bold" href="/categories">View All Categories</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">More</a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item" href="/contact">Contact</a></li>
                            <li><a class="dropdown-item" href="/account/profile">Account</a></li>
                            <li><a class="dropdown-item" href="/cart">Cart</a></li>
                        </ul>
                    </li>
                </ul>

                <!-- Center logo (desktop only) -->
                <div class="d-none d-lg-flex col-lg-4 justify-content-center">
                    <a class="navbar-brand m-0" href="/">
                        <img src="/images/Logo.png" alt="InwZa Bookstore Logo" class="navbar-logo" width="100">
                    </a>
                </div>

                <!-- Right: search + button -->
                <div class="d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center ms-lg-auto col-lg-4 justify-content-lg-end gap-2">
                    <form action="/search" method="GET" class="d-flex position-relative my-2 my-lg-0">
                        <input name="q" class="form-control rounded-pill pe-5 bg-light border-0 w-100" type="search" placeholder="Search products..." aria-label="Search">
                        <button type="submit" class="btn position-absolute top-50 end-0 translate-middle-y border-0 p-0 me-3">
                            <i class="bi bi-search text-muted"></i>
                        </button>
                    </form>
                    <a href="/cart" class="btn btn-outline-dark rounded-pill px-3 mt-2 mt-lg-0 position-relative"><i class="bi bi-cart3 fs-5"></i><span class="cart-badge badge bg-primary rounded-pill position-absolute" style="<%= (typeof cartCount !== 'undefined' && cartCount > 0) ? '' : 'display:none;' %>font-size:0.6rem;top:-5px;right:-5px;"><%= (typeof cartCount !== 'undefined') ? cartCount : 0 %></span></a>
                    <% if (typeof user !== 'undefined' && user) { %>
                    <div class="dropdown mt-2 mt-lg-0">
                        <a class="btn btn-primary rounded-pill px-4 dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"><%= user.username %></a>
                        <ul class="dropdown-menu border-0 shadow">
                            <li><a class="dropdown-item" href="/account/profile">Profile</a></li>
                            <li><a class="dropdown-item" href="/account/orders">Order History</a></li>
                            <li><a class="dropdown-item" href="/account/wishlist">Wishlist</a></li>
                            <li><a class="dropdown-item" href="/account/addresses">Address Book</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/auth/logout">Logout</a></li>
                        </ul>
                    </div>
                    <% } else { %>
                    <a href="/auth/login" class="btn btn-primary rounded-pill px-4 mt-2 mt-lg-0">Login</a>
                    <% } %>
                </div>
            </div>

        </div>
    </nav>

    <section class="container my-5 text-center">
        <h1 class="display-5 fw-bold mb-3">All books products</h1>
        <p class="text-muted">Discover our curated collection of literature and non-fiction.</p>
    </section>

    <section class="container mb-5">
        <div class="text-center mb-4">
            <span class="text-muted text-uppercase small fw-bold">Collection</span>
            <h2 class="fw-bold">Books</h2>
            <p class="text-muted small">Explore the stories that enrich every genre.</p>
        </div>

        <div id="product-list" class="row justify-content-center">
                <% products.forEach(function(product) { %>
                <% const images = typeof product.product_images === 'string' ? JSON.parse(product.product_images) : product.product_images; %>
                <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                    <div class="card border-0 h-100 bg-transparent text-center book-card-hover" data-product-id="<%= product.product_id %>" style="cursor:pointer;">
                        <img src="/images/products/<%= images && images[0] ? images[0] : 'fiction-01.png' %>" class="card-img-top rounded-4 shadow-sm mb-3" alt="<%= product.product_name %>" style="height: 320px; object-fit: cover;">
                        <h6 class="fw-bold mb-1"><%= product.product_name %></h6>
                        <p class="text-muted small mb-1"><%= product.author || 'Unknown Author' %></p>
                        <p class="fw-bold">$<%= parseFloat(product.product_price).toFixed(2) %></p>
                    </div>
                </div>
                <% }); %>
            </div>

        <nav aria-label="Product pagination" class="mt-5">
            <ul id="pagination-controls" class="pagination justify-content-center">
                </ul>
        </nav>
    </section>

    <footer class="container py-5 border-top">
        <div class="row">
            <div class="col-12 col-md-4 mb-4">
                <h5 class="fw-bold mb-3">InwZa Bookstore</h5>
                <p class="text-muted small">Address: Level 2, 45 King Street, Sydney NSW 2000</p>
                <p class="text-muted small">Contact: 1800 555 123<br><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="4b232e2727240b22253c312a29242420383f24392e65282426">[email&#160;protected]</a></p>
            </div>
            <div class="col-12 mt-4 text-muted small text-center">
                <p>&copy; 2026 InwZa Bookstore. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/cart.js"></script>
    <script src="/js/wishlist.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/pagination.js"></script>
</body>
</html>