<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Account - InwZa Bookstore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body class="bg-white">

    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm py-3">
        <div class="container d-flex align-items-center flex-wrap">

            <!-- Left: Logo on mobile (centered via CSS), Toggler on right -->
            <a class="navbar-brand d-lg-none mx-auto" href="/">
                <img src="/images/Logo.png" alt="InwZa Bookstore Logo" class="navbar-logo" width="100">
            </a>
            <button class="navbar-toggler border-0 position-absolute end-0 me-3 d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Desktop 3-column layout -->
            <div class="collapse navbar-collapse" id="mainNavbar">
                <!-- Left nav links -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 col-lg-4">
                    <li class="nav-item"><a class="nav-link fw-bold text-dark" href="/products">All Products</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="categoryDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Categories</a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="categoryDropdown">
                            <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                                <% categories.forEach(cat => { %>
                                    <% const slugMap = { 'Fiction': 'fiction', 'Non-Fiction': 'nonfiction', "Children": 'children', "Mystery & Thriller": 'mystery', "Science & Technology": 'science' }; %>
                                    <li><a class="dropdown-item" href="/category/<%= slugMap[cat.category_name] || cat.category_name.toLowerCase().replace(/[^a-z]+/g, '') %>"><%= cat.category_name %></a></li>
                                <% }); %>
                            <% } else { %>
                            <li><a class="dropdown-item" href="/category/fiction">Fiction</a></li>
                            <li><a class="dropdown-item" href="/category/nonfiction">Non-fiction</a></li>
                            <li><a class="dropdown-item" href="/category/children">Children's Books</a></li>
                            <li><a class="dropdown-item" href="/category/mystery">Mystery & Thriller</a></li>
                            <li><a class="dropdown-item" href="/category/science">Science & Tech</a></li>
                            <% } %>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-primary fw-bold" href="/categories">View All Categories</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">More</a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item" href="/contact">Contact</a></li>
                            <li><a class="dropdown-item" href="/account/profile">Account</a></li>
                            <li><a class="dropdown-item" href="/cart">Cart</a></li>
                        </ul>
                    </li>
                </ul>

                <!-- Center logo (desktop only) -->
                <div class="d-none d-lg-flex col-lg-4 justify-content-center">
                    <a class="navbar-brand m-0" href="/">
                        <img src="/images/Logo.png" alt="InwZa Bookstore Logo" class="navbar-logo" width="100">
                    </a>
                </div>

                <!-- Right: search + button -->
                <div class="d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center ms-lg-auto col-lg-4 justify-content-lg-end gap-2">
                    <form action="/search" method="GET" class="d-flex position-relative my-2 my-lg-0">
                        <input name="q" class="form-control rounded-pill pe-5 bg-light border-0 w-100" type="search" placeholder="Search products..." aria-label="Search">
                        <button type="submit" class="btn position-absolute top-50 end-0 translate-middle-y border-0 p-0 me-3">
                            <i class="bi bi-search text-muted"></i>
                        </button>
                    </form>
                    <a href="/cart" class="btn btn-outline-dark rounded-pill px-3 mt-2 mt-lg-0 position-relative"><i class="bi bi-cart3 fs-5"></i><% if (typeof cartCount !== 'undefined' && cartCount > 0) { %><span class="cart-badge badge bg-primary rounded-pill position-absolute" style="font-size:0.6rem;top:-5px;right:-5px;"><%= cartCount %></span><% } %></a>
                    <% if (typeof user !== 'undefined' && user) { %>
                        <div class="dropdown mt-2 mt-lg-0">
                            <a class="btn btn-outline-dark rounded-pill px-4 dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i> <%= user.username %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                                <li><a class="dropdown-item" href="/account/profile">Profile</a></li>
                                <li><a class="dropdown-item" href="/account/orders">Order History</a></li>
                                <li><a class="dropdown-item" href="/account/wishlist">Wishlist</a></li>
                                <li><a class="dropdown-item" href="/account/addresses">Address Book</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="/auth/logout">Logout</a></li>
                            </ul>
                        </div>
                    <% } else { %>
                    <a href="/auth/login" class="btn btn-primary rounded-pill px-4 mt-2 mt-lg-0">Login</a>
                    <% } %>
                </div>
            </div>

        </div>
    </nav>

    <section class="container my-5 pt-4">
        <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>
        <div class="row justify-content-between g-5">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-4"><%= typeof profileUser !== 'undefined' && profileUser ? profileUser.username : 'Username here' %></h1>
                <p class="text-dark fw-medium mb-4" style="line-height: 1.8;">
                    Discover a world of stories, knowledge, and inspiration. From bestsellers to hidden gems, find the perfect book for every moment.
                </p>
                <div class="d-flex gap-2">
                    <span class="badge bg-white text-dark border px-3 py-2 rounded-pill fw-normal"><%= typeof profileUser !== 'undefined' && profileUser && profileUser.email ? profileUser.email : 'Email' %></span>
                    <span class="badge bg-white text-dark border px-3 py-2 rounded-pill fw-normal"><%= typeof profileUser !== 'undefined' && profileUser && profileUser.phone ? profileUser.phone : 'No phone' %></span>
                    <span class="badge bg-white text-dark border px-3 py-2 rounded-pill fw-normal">Member</span>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="row g-4">
                    <div class="col-sm-6">
                        <h6 class="fw-bold mb-2">Order History</h6>
                        <a href="/account/orders" class="text-dark fw-bold text-decoration-underline small">Your order</a>
                    </div>
                    <div class="col-sm-6">
                        <h6 class="fw-bold mb-2">Wishlist</h6>
                        <a href="/account/wishlist" class="text-dark fw-bold text-decoration-underline small">Your Wishlist</a>
                    </div>
                    <div class="col-sm-6 mt-4">
                        <h6 class="fw-bold mb-2">Address Book</h6>
                        <a href="/account/addresses" class="text-dark fw-bold text-decoration-underline small">Your address</a>
                    </div>
                    <div class="col-sm-6 mt-4">
                        <h6 class="fw-bold mb-2">Payment Methods</h6>
                        <a href="/checkout/payment" class="text-dark fw-bold text-decoration-underline small">Your pay</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Edit Profile Form -->
    <section class="container my-4">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border rounded-3 p-4 mb-4">
                    <h4 class="fw-bold mb-4">Edit Profile</h4>
                    <form action="/account/profile" method="POST">
                        <div class="mb-3">
                            <label for="username" class="form-label fw-bold">Username</label>
                            <input type="text" class="form-control" id="username" name="username" value="<%= typeof profileUser !== 'undefined' && profileUser ? profileUser.username : '' %>" required>
                        </div>
                        <div class="mb-3">
                            <label for="email" class="form-label fw-bold">Email</label>
                            <input type="email" class="form-control" id="email" name="email" value="<%= typeof profileUser !== 'undefined' && profileUser ? profileUser.email : '' %>" required>
                        </div>
                        <div class="mb-3">
                            <label for="phone" class="form-label fw-bold">Phone</label>
                            <input type="text" class="form-control" id="phone" name="phone" value="<%= typeof profileUser !== 'undefined' && profileUser && profileUser.phone ? profileUser.phone : '' %>">
                        </div>
                        <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Save Changes</button>
                    </form>
                </div>

                <div class="card border rounded-3 p-4">
                    <h4 class="fw-bold mb-4">Change Password</h4>
                    <form action="/account/password" method="POST">
                        <div class="mb-3">
                            <label for="currentPassword" class="form-label fw-bold">Current Password</label>
                            <input type="password" class="form-control" id="currentPassword" name="currentPassword" required>
                        </div>
                        <div class="mb-3">
                            <label for="newPassword" class="form-label fw-bold">New Password</label>
                            <input type="password" class="form-control" id="newPassword" name="newPassword" required>
                        </div>
                        <div class="mb-3">
                            <label for="confirmPassword" class="form-label fw-bold">Confirm New Password</label>
                            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required>
                        </div>
                        <button type="submit" class="btn btn-outline-dark rounded-pill px-4 fw-bold">Update Password</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <section class="container my-5 py-5 w-75 border-top">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Help</h2>
            <p class="text-muted">Find answers to common questions about managing your account.</p>
        </div>

        <div class="mb-5">
            <h6 class="fw-bold mb-3">How do I reset my password?</h6>
            <p class="text-muted small mb-4">Click the "Forgot Password" link on the login page. Enter your email address and follow the instructions sent to your inbox. You'll receive a secure link to create a new password within minutes.</p>

            <h6 class="fw-bold mb-3">Can I change my email address?</h6>
            <p class="text-muted small mb-4">Yes. Go to your account settings and select "Email Address." Enter your new email and verify it through the confirmation link we send you. Your account will be updated immediately.</p>

            <h6 class="fw-bold mb-3">How is my payment information protected?</h6>
            <p class="text-muted small mb-4">We use industry-standard encryption to protect all payment data. Your card details are never stored on our servers. We comply with PCI DSS security standards to keep your information safe.</p>

            <h6 class="fw-bold mb-3">What happens to my order history?</h6>
            <p class="text-muted small mb-4">Your complete order history is saved in your account indefinitely. You can view past purchases, track shipments, and reorder items anytime. This information is private and accessible only to you.</p>

            <h6 class="fw-bold mb-3">Can I delete my account?</h6>
            <p class="text-muted small">You can request account deletion from your settings. We'll remove your personal information within thirty days, though order history may be retained for legal and tax purposes.</p>
        </div>
        
        <div class="text-center mt-5 pt-4">
            <h3 class="fw-bold mb-3">Still have questions?</h3>
            <p class="text-muted small mb-4">Reach out to our support team anytime.</p>
            <a href="/contact" class="btn btn-light border rounded-pill px-5 fw-bold shadow-sm">Contact</a>
        </div>
    </section>

    <footer class="container py-5 border-top">
        <div class="text-center text-muted small pt-4 mt-4 border-top">
            <p>&copy; 2026 InwZa Bookstore. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/cart.js"></script>
    <script src="/js/wishlist.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/account.js"></script>
</body>
</html>