<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - InwZa Bookstore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body class="bg-white">

    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm py-3">
        <div class="container d-flex align-items-center flex-wrap">

            <!-- Left: Logo on mobile (centered via CSS), Toggler on right -->
            <a class="navbar-brand d-lg-none mx-auto" href="/">
                <img src="/images/Logo.png" alt="InwZa Bookstore Logo" class="navbar-logo" width="100">
            </a>
            <button class="navbar-toggler border-0 position-absolute end-0 me-3 d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Desktop 3-column layout -->
            <div class="collapse navbar-collapse" id="mainNavbar">
                <!-- Left nav links -->
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 col-lg-4">
                    <li class="nav-item"><a class="nav-link fw-bold text-dark" href="/products">All Products</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="categoryDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Categories</a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="categoryDropdown">
                            <li><a class="dropdown-item" href="/category/fiction">Fiction</a></li>
                            <li><a class="dropdown-item" href="/category/nonfiction">Non-fiction</a></li>
                            <li><a class="dropdown-item" href="/category/children">Children\'s Books</a></li>
                            <li><a class="dropdown-item" href="/category/mystery">Mystery & Thriller</a></li>
                            <li><a class="dropdown-item" href="/category/science">Science & Tech</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-primary fw-bold" href="/categories">View All Categories</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">More</a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item" href="/contact">Contact</a></li>
                            <li><a class="dropdown-item" href="/account/profile">Account</a></li>
                            <li><a class="dropdown-item" href="/cart">Cart</a></li>
                        </ul>
                    </li>
                </ul>

                <!-- Center logo (desktop only) -->
                <div class="d-none d-lg-flex col-lg-4 justify-content-center">
                    <a class="navbar-brand m-0" href="/">
                        <img src="/images/Logo.png" alt="InwZa Bookstore Logo" class="navbar-logo" width="100">
                    </a>
                </div>

                <!-- Right: search + button -->
                <div class="d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center ms-lg-auto col-lg-4 justify-content-lg-end gap-2">
                    <form action="/search" method="GET" class="d-flex position-relative my-2 my-lg-0">
                        <input name="q" class="form-control rounded-pill pe-5 bg-light border-0 w-100" type="search" placeholder="Search products..." aria-label="Search">
                        <i class="bi bi-search position-absolute top-50 end-0 translate-middle-y me-3 text-muted"></i>
                    </form>
                    <a href="/cart" class="btn btn-outline-dark rounded-pill px-3 mt-2 mt-lg-0 position-relative"><i class="bi bi-cart3 fs-5"></i><% if (cartCount > 0) { %><span class="cart-badge badge bg-primary rounded-pill position-absolute" style="font-size:0.6rem;top:-5px;right:-5px;"><%= cartCount %></span><% } %></a>
                    <% if (user) { %>
                    <div class="dropdown mt-2 mt-lg-0">
                        <a class="btn btn-primary rounded-pill px-4 dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"><%= user.username %></a>
                        <ul class="dropdown-menu border-0 shadow">
                            <li><a class="dropdown-item" href="/account/profile">Profile</a></li>
                            <li><a class="dropdown-item" href="/account/orders">Order History</a></li>
                            <li><a class="dropdown-item" href="/account/wishlist">Wishlist</a></li>
                            <li><a class="dropdown-item" href="/account/addresses">Address Book</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/auth/logout">Logout</a></li>
                        </ul>
                    </div>
                    <% } else { %>
                    <a href="/auth/login" class="btn btn-primary rounded-pill px-4 mt-2 mt-lg-0">Login</a>
                    <% } %>
                </div>
            </div>

        </div>
    </nav>

    <section class="container mt-5 pt-4 text-center">
        <h1 class="display-4 fw-bold mb-3">Our Contact</h1>
        <p class="text-muted">We're here to help and answer any question you might have.</p>
    </section>

    <section class="container my-5 py-5">
        <div class="row g-5">
            <div class="col-lg-4">
                <span class="text-muted text-uppercase small fw-bold">Chat</span>
                <h2 class="fw-bold mb-5">Get in touch</h2>
                <!-- line 84-86 แสดง Address -->
                <div class="mb-4">
                    <h6 class="fw-bold"><i class="bi bi-geo-alt me-2 text-primary"></i> Address</h6>
                    <p class="text-muted small ms-4 mb-0">Level 2, 45 King Street,<br>Sydney NSW 2000, Australia</p>
                </div>
                <div class="mb-4">
                    <h6 class="fw-bold"><i class="bi bi-telephone me-2 text-primary"></i> Phone</h6>
                    <p class="text-muted small ms-4 mb-0">Mon-Fri from 9am to 6pm.<br>+1 800 555 123</p>
                </div>
                <div class="mb-4">
                    <h6 class="fw-bold"><i class="bi bi-envelope me-2 text-primary"></i> Email</h6>
                    <p class="text-muted small ms-4 mb-0">Our friendly team is here to help.<br><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="dfb7bab3b3b09fb6b1a8a5bebdb0b0b4acabb0adbaf1bcb0b2">[email&#160;protected]</a></p>
                </div>
            </div>
             <!-- line 99-107 Map API pin location ตรงกับ address -->
            <div class="col-lg-8">
                <div class="card border-0 rounded-4 overflow-hidden h-100 shadow-sm" style="min-height: 400px;">
                    <iframe 
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d26544.75549007425!2d151.1960255!3d-33.8688197!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b12ae235c441b4f%3A0x5017d681632a680!2sSydney%20NSW%202000%2C%20Australia!5e0!3m2!1sen!2sth!4v1700000000000!5m2!1sen!2sth" 
                        width="100%" 
                        height="100%" 
                        style="border:0;" 
                        allowfullscreen="" 
                        loading="lazy" 
                        referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-light py-5 my-5">
        <div class="container py-4">
            <div class="text-center mb-5">
                <span class="text-muted text-uppercase small fw-bold">Visit us</span>
                <h2 class="fw-bold">Locations</h2>
                <p class="text-muted small">Come visit our stores to browse our collection in person.</p>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card border-0 bg-transparent text-center">
                        <img src="https://images.unsplash.com/photo-1568668392383-58c369615742?q=80&w=800&auto=format&fit=crop" class="card-img-top rounded-4 mb-3" alt="Sydney Store" style="height: 300px; object-fit: cover;">
                        <div class="card-body">
                            <h4 class="fw-bold">Sydney</h4>
                            <p class="text-muted small mb-3">Level 2, 45 King Street, Sydney NSW</p>
                            <a href="#" class="text-dark fw-bold text-decoration-none">Get directions <i class="bi bi-chevron-right small"></i></a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 bg-transparent text-center">
                        <img src="https://images.unsplash.com/photo-1521587760476-6c12a4b040da?q=80&w=800&auto=format&fit=crop" class="card-img-top rounded-4 mb-3" alt="New York Store" style="height: 300px; object-fit: cover;">
                        <div class="card-body">
                            <h4 class="fw-bold">New York</h4>
                            <p class="text-muted small mb-3">123 Broadway, New York, NY 10001</p>
                            <a href="#" class="text-dark fw-bold text-decoration-none">Get directions <i class="bi bi-chevron-right small"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="container my-5 py-5">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="row g-5">
                    <div class="col-md-5">
                        <span class="text-muted text-uppercase small fw-bold">Write</span>
                        <h2 class="fw-bold mb-4">Send a message</h2>
                        <p class="text-muted small mb-5">Fill out the form and our team will get back to you within 24 hours.</p>
                        
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-telephone fs-4 me-3 text-muted"></i>
                            <div>
                                <h6 class="fw-bold mb-0">Call us</h6>
                                <p class="text-muted small mb-0">+1 800 555 123</p>
                            </div>
                        </div>
                        <div class="d-flex align-items-center">
                            <i class="bi bi-envelope fs-4 me-3 text-muted"></i>
                            <div>
                                <h6 class="fw-bold mb-0">Email us</h6>
                                <p class="text-muted small mb-0"><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="036b666f6f6c436a6d747962616c6c6870776c71662d606c6e">[email&#160;protected]</a></p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-7">
                        <form action="#">
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small">First name</label>
                                    <input type="text" class="form-control bg-light border-0 rounded-3 py-2" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small">Last name</label>
                                    <input type="text" class="form-control bg-light border-0 rounded-3 py-2" required>
                                </div>
                            </div>
                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small">Email</label>
                                    <input type="email" class="form-control bg-light border-0 rounded-3 py-2" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small">Phone number</label>
                                    <input type="tel" class="form-control bg-light border-0 rounded-3 py-2">
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold small">Subject</label>
                                <select class="form-select bg-light border-0 rounded-3 py-2">
                                    <option selected>General Inquiry</option>
                                    <option value="1">Order Status</option>
                                    <option value="2">Returns & Refunds</option>
                                    <option value="3">Partnerships</option>
                                </select>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold small">Message</label>
                                <textarea class="form-control bg-light border-0 rounded-3" rows="5" placeholder="Leave us a message..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary rounded-pill py-2 px-5 fw-bold">Send</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="container my-5 py-5 w-75 border-top">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Questions</h2>
            <p class="text-muted">Find answers to what customers are asking most.</p>
        </div>

        <div class="accordion accordion-flush" id="faqAccordion">
            <div class="accordion-item border-bottom mb-3">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed bg-transparent fw-bold px-0" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                        Where is my order?
                    </button>
                </h2>
                <div id="faq1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body px-0 text-muted small">
                        You can track your order status in your Account page, or click the tracking link in your shipping confirmation email.
                    </div>
                </div>
            </div>
            <div class="accordion-item border-bottom mb-3">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed bg-transparent fw-bold px-0" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                        Can I cancel my order?
                    </button>
                </h2>
                <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                    <div class="accordion-body px-0 text-muted small">
                        Orders can be cancelled within 1 hour of placing them. After that, they enter our processing system and cannot be changed.
                    </div>
                </div>
            </div>
        </div>
        
        <div class="text-center mt-5">
            <p class="mb-2 fw-bold">Still need help?</p>
            <a href="#top" class="btn btn-light border rounded-pill px-4 shadow-sm">Back to top</a>
        </div>
    </section>

    <footer class="container py-5 border-top">
        <div class="row">
            <div class="col-12 col-md-4 mb-4">
                <img src="/images/Logo.png" alt="Logo" width="80" class="mb-3 rounded">
                <p class="text-muted small">Address:<br>Level 2, 45 King Street, Sydney NSW 2000</p>
                <p class="text-muted small">Contact:<br>1800 555 123<br><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="f29a979e9e9db29b9c858893909d9d9981869d8097dc919d9f">[email&#160;protected]</a></p>
                <div class="d-flex gap-3 mt-3">
                    <a href="#" class="text-dark"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="text-dark"><i class="bi bi-twitter"></i></a>
                    <a href="#" class="text-dark"><i class="bi bi-instagram"></i></a>
                </div>
            </div>
            <div class="col-6 col-md-4 mb-4">
                <ul class="list-unstyled text-muted small lh-lg">
                    <li><a href="/products" class="text-decoration-none text-muted">All products</a></li>
                    <li><a href="/categories" class="text-decoration-none text-muted">Categories</a></li>
                    <li><a href="/contact" class="text-decoration-none text-muted">Contact us</a></li>
                </ul>
            </div>
            <div class="col-6 col-md-4 mb-4">
                <ul class="list-unstyled text-muted small lh-lg">
                    <li><a href="/account/profile" class="text-decoration-none text-muted">Account</a></li>
                    <li><a href="/cart" class="text-decoration-none text-muted">Cart</a></li>
                    <li><a href="/faq" class="text-decoration-none text-muted">FAQ</a></li>
                </ul>
            </div>
        </div>
        <div class="d-flex justify-content-between pt-4 mt-4 border-top text-muted small">
            <p>&copy; 2026 InwZa Bookstore. All rights reserved.</p>
            <div class="d-flex gap-3">
                <a href="/condition" class="text-decoration-none text-muted">Privacy policy</a>
                <a href="/condition" class="text-decoration-none text-muted">Terms of service</a>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/cart.js"></script>
    <script src="/js/wishlist.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>
