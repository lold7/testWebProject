<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Wishlist - InwZa Bookstore</title>
    <meta name="description" content="Save your favorite books for later and come back whenever you're ready to buy from InwZa Bookstore.">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        /* ---------- Wishlist Page Styles ---------- */
        .wishlist-hero {
            padding: 4rem 0 3rem;
        }
        .wishlist-hero h1 {
            font-size: 2.8rem;
            font-weight: 700;
        }
        .wishlist-hero p {
            color: #6c757d;
            font-size: 1.05rem;
            margin-top: 0.5rem;
        }

        /* Ecommerce Product Section */
        .product-section {
            padding: 3rem 0 4rem;
        }
        .product-section .section-label {
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            color: #6c757d;
            letter-spacing: 0.05em;
        }
        .product-section h2 {
            font-size: 2rem;
            font-weight: 700;
            margin-top: 0.25rem;
        }
        .product-section .section-desc {
            color: #6c757d;
            font-size: 0.95rem;
            margin-top: 0.5rem;
            max-width: 700px;
        }
        .stat-number {
            font-size: 2.2rem;
            font-weight: 700;
            line-height: 1;
            margin-bottom: 0.25rem;
        }
        .stat-label {
            font-size: 0.85rem;
            color: #6c757d;
        }

        /* Features List Section */
        .features-section {
            background-color: #eef1f6;
            padding: 4rem 0;
        }
        .features-section .section-label {
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            color: #6c757d;
            letter-spacing: 0.05em;
        }
        .features-section h2 {
            font-size: 2rem;
            font-weight: 700;
            margin-top: 0.25rem;
        }
        .features-section .section-desc {
            color: #6c757d;
            font-size: 0.95rem;
            margin-top: 0.25rem;
        }
        .action-card {
            background: #fff;
            border: 1px solid #e0e4ea;
            border-radius: 1rem;
            padding: 2.5rem 2rem 2rem;
            height: 100%;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .action-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.07);
        }
        .action-card .card-tag {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            color: #6c757d;
            letter-spacing: 0.04em;
        }
        .action-card h3 {
            font-size: 1.5rem;
            font-weight: 700;
            margin-top: 0.4rem;
            line-height: 1.3;
        }
        .action-card p {
            color: #6c757d;
            font-size: 0.9rem;
            margin-top: 0.5rem;
        }

        /* Testimonial Section */
        .testimonial-section {
            padding: 4rem 0;
        }
        .testimonial-section h2 {
            font-size: 2rem;
            font-weight: 700;
        }
        .testimonial-section .subtitle {
            color: #6c757d;
            font-size: 0.95rem;
        }
        .testimonial-card {
            border: 1px solid #e9ecef;
            border-radius: 1rem;
            padding: 2rem;
            background: #fff;
        }
        .testimonial-card .quote {
            font-size: 0.95rem;
            font-style: italic;
            color: #333;
            line-height: 1.6;
        }
        .testimonial-card .author-name {
            font-weight: 700;
            font-size: 0.9rem;
        }
        .testimonial-card .author-role {
            font-size: 0.8rem;
            color: #6c757d;
        }
        .testimonial-card .view-link {
            font-weight: 600;
            text-decoration: none;
            color: #1a1a1a;
            font-size: 0.9rem;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            transition: gap 0.2s;
        }
        .testimonial-card .view-link:hover {
            gap: 0.6rem;
            color: #3b5bdb;
        }

        /* Mobile */
        @media (max-width: 767.98px) {
            .wishlist-hero h1 { font-size: 2rem; }
            .product-section h2,
            .features-section h2,
            .testimonial-section h2 { font-size: 1.5rem; }
            .action-card { padding: 2rem 1.5rem 1.5rem; }
            .action-card h3 { font-size: 1.25rem; }
            .stat-number { font-size: 1.8rem; }
        }
    </style>
</head>
<body>

    <!-- ========== NAVBAR ========== -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm py-3">
        <div class="container d-flex align-items-center flex-wrap">
            <a class="navbar-brand d-lg-none mx-auto" href="/">
                <img src="/images/Logo.png" alt="InwZa Bookstore Logo" class="navbar-logo" width="100">
            </a>
            <button class="navbar-toggler border-0 position-absolute end-0 me-3 d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 col-lg-4">
                    <li class="nav-item"><a class="nav-link fw-bold text-dark" href="/products">All Products</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="categoryDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Categories</a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="categoryDropdown">
                            <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                                <% categories.forEach(cat => { %>
                                    <% const slugMap = { 'Fiction': 'fiction', 'Non-Fiction': 'nonfiction', "Children": 'children', "Mystery & Thriller": 'mystery', "Science & Technology": 'science' }; %>
                                    <li><a class="dropdown-item" href="/category/<%= slugMap[cat.category_name] || cat.category_name.toLowerCase().replace(/[^a-z]+/g, '') %>"><%= cat.category_name %></a></li>
                                <% }); %>
                            <% } else { %>
                            <li><a class="dropdown-item" href="/category/fiction">Fiction</a></li>
                            <li><a class="dropdown-item" href="/category/nonfiction">Non-fiction</a></li>
                            <li><a class="dropdown-item" href="/category/children">Children's Books</a></li>
                            <li><a class="dropdown-item" href="/category/mystery">Mystery & Thriller</a></li>
                            <li><a class="dropdown-item" href="/category/science">Science & Tech</a></li>
                            <% } %>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-primary fw-bold" href="/categories">View All Categories</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">More</a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item" href="/contact">Contact</a></li>
                            <li><a class="dropdown-item" href="/account/profile">Account</a></li>
                            <li><a class="dropdown-item" href="/cart">Cart</a></li>
                        </ul>
                    </li>
                </ul>

                <div class="d-none d-lg-flex col-lg-4 justify-content-center">
                    <a class="navbar-brand m-0" href="/">
                        <img src="/images/Logo.png" alt="InwZa Bookstore Logo" class="navbar-logo" width="100">
                    </a>
                </div>

                <div class="d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center ms-lg-auto col-lg-4 justify-content-lg-end gap-2">
                    <form action="/search" method="GET" class="d-flex position-relative my-2 my-lg-0">
                        <input name="q" class="form-control rounded-pill pe-5 bg-light border-0 w-100" type="search" placeholder="Search products..." aria-label="Search">
                        <button type="submit" class="btn position-absolute top-50 end-0 translate-middle-y border-0 p-0 me-3">
                            <i class="bi bi-search text-muted"></i>
                        </button>
                    </form>
                    <a href="/cart" class="btn btn-outline-dark rounded-pill px-3 mt-2 mt-lg-0 position-relative"><i class="bi bi-cart3 fs-5"></i><% if (typeof cartCount !== 'undefined' && cartCount > 0) { %><span class="cart-badge badge bg-primary rounded-pill position-absolute" style="font-size:0.6rem;top:-5px;right:-5px;"><%= cartCount %></span><% } %></a>
                    <% if (typeof user !== 'undefined' && user) { %>
                        <div class="dropdown mt-2 mt-lg-0">
                            <a class="btn btn-outline-dark rounded-pill px-4 dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i> <%= user.username %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                                <li><a class="dropdown-item" href="/account/profile">Profile</a></li>
                                <li><a class="dropdown-item" href="/account/orders">Order History</a></li>
                                <li><a class="dropdown-item" href="/account/wishlist">Wishlist</a></li>
                                <li><a class="dropdown-item" href="/account/addresses">Address Book</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="/auth/logout">Logout</a></li>
                            </ul>
                        </div>
                    <% } else { %>
                    <a href="/auth/login" class="btn btn-primary rounded-pill px-4 mt-2 mt-lg-0">Login</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <!-- ========== HEADER SECTION ========== -->
    <section class="wishlist-hero text-center" id="wishlist-header">
        <div class="container">
            <h1>My wishlist</h1>
            <p>Save your favorite books for later and come back whenever you're ready to buy.</p>
        </div>
    </section>

    <!-- ========== ECOMMERCE PRODUCT SECTION ========== -->
    <section class="product-section" id="product-section">
        <div class="container">
            <span class="section-label">Saved</span>
            <h2>Your books are waiting here</h2>
            <p class="section-desc">Each title you've saved appears with its cover, price, and formats. Move anything to your cart when you're ready to purchase.</p>

            <div class="row mt-4 mb-4" style="max-width: 400px;">
                <div class="col-6">
                    <div class="stat-number"><%= typeof wishlistItems !== 'undefined' ? wishlistItems.length : 0 %></div>
                    <div class="stat-label">Books in your wishlist</div>
                </div>
                <div class="col-6">
                    <div class="stat-number">0</div>
                    <div class="stat-label">Items added to cart this month</div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <a href="#" class="btn btn-outline-dark rounded-pill px-4 btn-sm">Clear</a>
                <a href="/cart" class="btn btn-outline-dark rounded-pill px-4 btn-sm d-inline-flex align-items-center gap-1">Cart <i class="bi bi-chevron-right small"></i></a>
            </div>

            <div id="wishlist-items" class="mt-4">
                <% if (typeof wishlistItems !== 'undefined' && wishlistItems.length > 0) { %>
                    <div class="row g-4">
                    <% wishlistItems.forEach(function(item) { %>
                        <% const imgs = typeof item.product_images === 'string' ? JSON.parse(item.product_images) : (item.product_images || []); %>
                        <div class="col-md-6 col-lg-4">
                            <div class="card border rounded-3 h-100">
                                <a href="/product/<%= item.product_id %>">
                                    <img src="/images/products/<%= imgs[0] || 'placeholder.jpg' %>" class="card-img-top" style="height:220px;object-fit:cover;" alt="<%= item.product_name %>">
                                </a>
                                <div class="card-body d-flex flex-column">
                                    <h6 class="fw-bold"><a href="/product/<%= item.product_id %>" class="text-dark text-decoration-none"><%= item.product_name %></a></h6>
                                    <% if (item.author) { %><small class="text-muted mb-2"><%= item.author %></small><% } %>
                                    <span class="fw-bold mb-3">$<%= parseFloat(item.product_price).toFixed(2) %></span>
                                    <div class="mt-auto d-flex gap-2">
                                        <button class="btn btn-primary btn-sm rounded-pill px-3 btn-add-to-cart-from-wishlist" data-product-id="<%= item.product_id %>">Add to Cart</button>
                                        <button class="btn btn-outline-danger btn-sm rounded-pill px-3 btn-remove-wishlist" data-product-id="<%= item.product_id %>"><i class="bi bi-trash"></i> Remove</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <i class="bi bi-heart fs-1 text-muted"></i>
                        <h5 class="mt-3 text-muted">Your wishlist is empty</h5>
                        <p class="text-muted">Browse our collection and save books you love.</p>
                        <a href="/products" class="btn btn-primary rounded-pill px-4">Browse Products</a>
                    </div>
                <% } %>
            </div>
        </div>
    </section>

    <!-- ========== FEATURES LIST SECTION ========== -->
    <section class="features-section" id="features-section">
        <div class="container">
            <div class="text-center mb-5">
                <span class="section-label">Manage</span>
                <h2>What you can do</h2>
                <p class="section-desc mx-auto">Keep track of books and move them to your cart whenever you're ready.</p>
            </div>

            <div class="row g-4 justify-content-center" style="max-width: 860px; margin: 0 auto;">
                <!-- Card 1: Add to cart -->
                <div class="col-md-6">
                    <div class="action-card">
                        <span class="card-tag">Action</span>
                        <h3>Add to cart from your wishlist</h3>
                        <p>Transfer any saved book directly to your shopping cart in one click.</p>
                        <div class="d-flex gap-2 mt-3">
                            <a href="#" class="btn btn-outline-dark rounded-pill px-3 btn-sm">Move</a>
                            <a href="#" class="btn btn-outline-dark rounded-pill px-3 btn-sm d-inline-flex align-items-center gap-1">Details <i class="bi bi-chevron-right small"></i></a>
                        </div>
                    </div>
                </div>
                <!-- Card 2: Remove books -->
                <div class="col-md-6">
                    <div class="action-card">
                        <span class="card-tag">Action</span>
                        <h3>Remove books you no longer want</h3>
                        <p>Easily tidy the list from your wishlist to keep it focused on what matters.</p>
                        <div class="d-flex gap-2 mt-3">
                            <a href="#" class="btn btn-outline-dark rounded-pill px-3 btn-sm">Remove</a>
                            <a href="#" class="btn btn-outline-dark rounded-pill px-3 btn-sm d-inline-flex align-items-center gap-1">Details <i class="bi bi-chevron-right small"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== TESTIMONIAL SECTION ========== -->
    <section class="testimonial-section" id="testimonial-section">
        <div class="container">
            <div class="row align-items-center g-4" style="max-width: 860px; margin: 0 auto;">
                <!-- Left side -->
                <div class="col-md-5">
                    <h2>Sign in now</h2>
                    <p class="subtitle">Access your wishlist everywhere</p>
                </div>
                <!-- Right side: Testimonial card -->
                <div class="col-md-7">
                    <div class="testimonial-card">
                        <p class="quote">"I keep my wishlist handy so I never forget a book I want to read."</p>
                        <div class="d-flex align-items-center gap-3 mt-3 mb-3">
                            <img src="https://ui-avatars.com/api/?name=Sarah+Chen&background=e9ecef&color=333&size=44&rounded=true&bold=true" alt="Sarah Chen" width="44" height="44" class="rounded-circle">
                            <div>
                                <div class="author-name">Sarah Chen</div>
                                <div class="author-role">Reader, Portland</div>
                            </div>
                        </div>
                        <a href="#" class="view-link">View her story <i class="bi bi-chevron-right"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== CTA SECTION ========== -->
    <section class="container my-5" id="cta-section">
        <div class="rounded-4 text-center text-white py-5 px-4 position-relative overflow-hidden" style="background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url('https://images.unsplash.com/photo-1507842217343-583bb7270b66?q=80&w=1200&auto=format&fit=crop') center/cover no-repeat; min-height: 220px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
            <h2 class="fw-bold display-6 mb-2">Start exploring our collection</h2>
            <p class="mb-4 opacity-75">Browse all products or go by category to find your next great read.</p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a href="/products" class="btn btn-primary rounded-pill px-4">Browse</a>
                <a href="/categories" class="btn btn-outline-light rounded-pill px-4">Categories</a>
            </div>
        </div>
    </section>

    <!-- ========== FOOTER ========== -->
    <footer class="site-footer py-5" id="site-footer">
        <div class="container">
            <div class="footer-inner">
                <div class="row">
                    <div class="col-12 col-md-4 mb-4 mb-md-0">
                        <h6>Address</h6>
                        <p class="mb-3">Level 2, 45 King Street, Sydney NSW 2000</p>
                        <h6>Contact</h6>
                        <p class="mb-1"><a href="tel:18005550123">1800 555 0123</a></p>
                        <p><a href="mailto:hello@minimalistbookstore.com">hello@minimalistbookstore.com</a></p>
                        <div class="footer-social mt-3">
                            <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                            <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                            <a href="#" aria-label="Twitter X"><i class="bi bi-twitter-x"></i></a>
                            <a href="#" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                            <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 footer-links">
                        <a href="/products">All products</a>
                        <a href="/categories">Categories</a>
                        <a href="/contact">Contact us</a>
                        <a href="#">About us</a>
                        <a href="/account/orders">Order history</a>
                    </div>
                    <div class="col-6 col-md-4 footer-links">
                        <a href="/account/wishlist">Wishlist</a>
                        <a href="/account/profile">Account</a>
                        <a href="/cart">Cart</a>
                        <a href="/faq">FAQ</a>
                        <a href="/condition">Returns</a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom d-flex flex-column flex-sm-row justify-content-between align-items-center">
                <p class="mb-2 mb-sm-0">&copy; 2025 Minimalist Bookstore. All rights reserved.</p>
                <div class="d-flex gap-3">
                    <a href="#">Privacy policy</a>
                    <a href="#">Terms of service</a>
                    <a href="#">Cookie settings</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/cart.js"></script>
    <script src="/js/wishlist.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>