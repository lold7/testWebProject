<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Address Book - InwZa Bookstore</title>
    <meta name="description" content="Manage your shipping addresses for faster checkout at InwZa Bookstore.">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body>

    <!-- ========== NAVBAR ========== -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm py-3">
        <div class="container d-flex align-items-center flex-wrap">
            <a class="navbar-brand d-lg-none mx-auto" href="/">
                <img src="/images/Logo.png" alt="InwZa Bookstore Logo" class="navbar-logo" width="100">
            </a>
            <button class="navbar-toggler border-0 position-absolute end-0 me-3 d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 col-lg-4">
                    <li class="nav-item"><a class="nav-link fw-bold text-dark" href="/products">All Products</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="categoryDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Categories</a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="categoryDropdown">
                            <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                                <% categories.forEach(cat => { %>
                                    <% const slugMap = { 'Fiction': 'fiction', 'Non-Fiction': 'nonfiction', "Children": 'children', "Mystery & Thriller": 'mystery', "Science & Technology": 'science' }; %>
                                    <li><a class="dropdown-item" href="/category/<%= slugMap[cat.category_name] || cat.category_name.toLowerCase().replace(/[^a-z]+/g, '') %>"><%= cat.category_name %></a></li>
                                <% }); %>
                            <% } else { %>
                            <li><a class="dropdown-item" href="/category/fiction">Fiction</a></li>
                            <li><a class="dropdown-item" href="/category/nonfiction">Non-fiction</a></li>
                            <li><a class="dropdown-item" href="/category/children">Children's Books</a></li>
                            <li><a class="dropdown-item" href="/category/mystery">Mystery & Thriller</a></li>
                            <li><a class="dropdown-item" href="/category/science">Science & Tech</a></li>
                            <% } %>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-primary fw-bold" href="/categories">View All Categories</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">More</a>
                        <ul class="dropdown-menu border-0 shadow" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item" href="/contact">Contact</a></li>
                            <li><a class="dropdown-item" href="/account/profile">Account</a></li>
                            <li><a class="dropdown-item" href="/cart">Cart</a></li>
                        </ul>
                    </li>
                </ul>

                <div class="d-none d-lg-flex col-lg-4 justify-content-center">
                    <a class="navbar-brand m-0" href="/">
                        <img src="/images/Logo.png" alt="InwZa Bookstore Logo" class="navbar-logo" width="100">
                    </a>
                </div>

                <div class="d-flex flex-column flex-lg-row align-items-stretch align-items-lg-center ms-lg-auto col-lg-4 justify-content-lg-end gap-2">
                    <form action="/search" method="GET" class="d-flex position-relative my-2 my-lg-0">
                        <input name="q" class="form-control rounded-pill pe-5 bg-light border-0 w-100" type="search" placeholder="Search products..." aria-label="Search">
                        <button type="submit" class="btn position-absolute top-50 end-0 translate-middle-y border-0 p-0 me-3">
                            <i class="bi bi-search text-muted"></i>
                        </button>
                    </form>
                    <a href="/cart" class="btn btn-outline-dark rounded-pill px-3 mt-2 mt-lg-0 position-relative"><i class="bi bi-cart3 fs-5"></i><% if (typeof cartCount !== 'undefined' && cartCount > 0) { %><span class="cart-badge badge bg-primary rounded-pill position-absolute" style="font-size:0.6rem;top:-5px;right:-5px;"><%= cartCount %></span><% } %></a>
                    <% if (typeof user !== 'undefined' && user) { %>
                        <div class="dropdown mt-2 mt-lg-0">
                            <a class="btn btn-outline-dark rounded-pill px-4 dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i> <%= user.username %>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                                <li><a class="dropdown-item" href="/account/profile">Profile</a></li>
                                <li><a class="dropdown-item" href="/account/orders">Order History</a></li>
                                <li><a class="dropdown-item" href="/account/wishlist">Wishlist</a></li>
                                <li><a class="dropdown-item" href="/account/addresses">Address Book</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="/auth/logout">Logout</a></li>
                            </ul>
                        </div>
                    <% } else { %>
                    <a href="/auth/login" class="btn btn-primary rounded-pill px-4 mt-2 mt-lg-0">Login</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <!-- ========== HEADER SECTION ========== -->
    <section class="address-hero text-center" id="address-header">
        <div class="container">
            <h1>My address book</h1>
            <p>Keep your shipping and billing information up to date for faster checkout.</p>
        </div>
    </section>

    <!-- Primary Address -->
    <section class="primary-address" id="primary-address">
        <div class="container">
            <% const defaultAddr = typeof addresses !== 'undefined' ? addresses.find(a => a.is_default) : null; %>
            <% if (defaultAddr) { %>
            <span class="badge-primary"><i class="bi bi-geo-alt-fill me-1"></i> Primary</span>
            <h2><%= defaultAddr.address_line %></h2>
            <p class="address-detail"><%= defaultAddr.city %><%= defaultAddr.province ? ', ' + defaultAddr.province : '' %> <%= defaultAddr.postal_code %></p>
            <% } else { %>
            <span class="badge-primary"><i class="bi bi-geo-alt-fill me-1"></i> Primary</span>
            <h2>No default address set</h2>
            <p class="address-detail">Add an address below to get started.</p>
            <% } %>
        </div>
    </section>

    <!-- ========== FEATURES LIST SECTION ========== -->
    <section class="address-list-section" id="features-section">
        <div class="container" style="max-width: 860px;">

            <div id="address-list" class="mb-4">
                <% if (typeof addresses !== 'undefined' && addresses.length > 0) { %>
                    <div class="row g-4">
                    <% addresses.forEach(function(addr) { %>
                        <div class="col-md-6">
                            <div class="address-entry p-3 border rounded-3 h-100">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <span class="entry-label"><i class="bi bi-geo-alt me-1"></i> <%= addr.label %></span>
                                    <% if (addr.is_default) { %>
                                        <span class="badge bg-primary rounded-pill">Default</span>
                                    <% } %>
                                </div>
                                <h4><%= addr.full_name %></h4>
                                <p class="entry-detail mb-1"><%= addr.address_line %></p>
                                <p class="entry-detail mb-1"><%= addr.city %><%= addr.province ? ', ' + addr.province : '' %> <%= addr.postal_code %></p>
                                <% if (addr.phone) { %><p class="entry-detail mb-1">Phone: <%= addr.phone %></p><% } %>
                                <div class="d-flex gap-2 mt-3 flex-wrap">
                                    <% if (!addr.is_default) { %>
                                    <form action="/account/addresses/default/<%= addr.address_id %>" method="POST" class="d-inline">
                                        <button type="submit" class="btn btn-outline-primary rounded-pill px-3 btn-sm">Set Default</button>
                                    </form>
                                    <% } %>
                                    <form action="/account/addresses/delete/<%= addr.address_id %>" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this address?');">
                                        <button type="submit" class="btn btn-outline-danger rounded-pill px-3 btn-sm">Delete</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                    </div>
                <% } else { %>
                    <div class="text-center py-4">
                        <i class="bi bi-geo-alt fs-1 text-muted"></i>
                        <p class="text-muted mt-2">No addresses saved yet. Add one below.</p>
                    </div>
                <% } %>
            </div>

        </div>
    </section>

    <!-- ========== CTA FORM SECTION ========== -->
    <section class="cta-form-section text-center" id="cta-form">
        <div class="container" style="max-width: 600px;">
            <h2>Add new address<br>Enter details</h2>
            <p>Tell us your address. You can save multiple addresses and set one as your default.</p>
            <form action="/account/addresses/add" method="POST" class="text-start mt-4">
                <div class="mb-3">
                    <label for="label" class="form-label fw-bold">Label</label>
                    <input type="text" class="form-control" id="label" name="label" placeholder="e.g. Home, Office" value="Home">
                </div>
                <div class="mb-3">
                    <label for="full_name" class="form-label fw-bold">Full Name</label>
                    <input type="text" class="form-control" id="full_name" name="full_name" placeholder="Your full name" required>
                </div>
                <div class="mb-3">
                    <label for="phone" class="form-label fw-bold">Phone</label>
                    <input type="text" class="form-control" id="phone" name="phone" placeholder="+1 (555) 000-0000">
                </div>
                <div class="mb-3">
                    <label for="address_line" class="form-label fw-bold">Address Line</label>
                    <input type="text" class="form-control" id="address_line" name="address_line" placeholder="e.g. 123 Main St, Apt 4" required>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label for="city" class="form-label fw-bold">City</label>
                        <input type="text" class="form-control" id="city" name="city" placeholder="City">
                    </div>
                    <div class="col-md-4">
                        <label for="province" class="form-label fw-bold">Province</label>
                        <input type="text" class="form-control" id="province" name="province" placeholder="Province/State">
                    </div>
                    <div class="col-md-4">
                        <label for="postal_code" class="form-label fw-bold">Postal Code</label>
                        <input type="text" class="form-control" id="postal_code" name="postal_code" placeholder="Postal code">
                    </div>
                </div>
                <div class="text-center">
                    <button type="submit" class="btn btn-save btn-primary rounded-pill px-5 fw-bold">Save Address</button>
                </div>
            </form>
            <p class="form-note mt-3">Saved addresses serve as your order destinations.</p>
        </div>
    </section>

    <!-- ========== FAQ SECTION ========== -->
    <section class="address-faq" id="faq-section">
        <div class="container" style="max-width: 780px;">
            <div class="text-center mb-5">
                <h2>Questions</h2>
                <p class="text-muted">Find answers to common questions about your address settings.</p>
            </div>

            <div class="accordion accordion-flush" id="addressFaqAccordion">

                <div class="accordion-item border-bottom mb-3">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed bg-transparent fw-bold px-0" type="button" data-bs-toggle="collapse" data-bs-target="#afaq1">
                            How do I set a default address?
                        </button>
                    </h2>
                    <div id="afaq1" class="accordion-collapse collapse" data-bs-parent="#addressFaqAccordion">
                        <div class="accordion-body px-0 text-muted">
                            Navigate to your address book, click the three-dot menu on any saved address, and select "Set as default." Your default address will be pre-filled during checkout for faster ordering.
                        </div>
                    </div>
                </div>

                <div class="accordion-item border-bottom mb-3">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed bg-transparent fw-bold px-0" type="button" data-bs-toggle="collapse" data-bs-target="#afaq2">
                            Can I save multiple addresses?
                        </button>
                    </h2>
                    <div id="afaq2" class="accordion-collapse collapse" data-bs-parent="#addressFaqAccordion">
                        <div class="accordion-body px-0 text-muted">
                            Yes, you can save as many addresses as you need. You can add home, office, or other addresses. During checkout, simply select the address you'd like to ship to from your saved list.
                        </div>
                    </div>
                </div>

                <div class="accordion-item border-bottom mb-3">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed bg-transparent fw-bold px-0" type="button" data-bs-toggle="collapse" data-bs-target="#afaq3">
                            How do I edit an address?
                        </button>
                    </h2>
                    <div id="afaq3" class="accordion-collapse collapse" data-bs-parent="#addressFaqAccordion">
                        <div class="accordion-body px-0 text-muted">
                            Click the "Edit" button on any saved address. Update the fields you need to change, then save. Your updated address will be used for future orders that select it.
                        </div>
                    </div>
                </div>

                <div class="accordion-item border-bottom mb-3">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed bg-transparent fw-bold px-0" type="button" data-bs-toggle="collapse" data-bs-target="#afaq4">
                            Can I delete an address?
                        </button>
                    </h2>
                    <div id="afaq4" class="accordion-collapse collapse" data-bs-parent="#addressFaqAccordion">
                        <div class="accordion-body px-0 text-muted">
                            Yes, click "Delete" next to the address you'd like to remove. If it's your default address, you'll need to assign a new default before deleting. Already-placed orders will not be affected.
                        </div>
                    </div>
                </div>

                <div class="accordion-item border-bottom mb-3">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed bg-transparent fw-bold px-0" type="button" data-bs-toggle="collapse" data-bs-target="#afaq5">
                            What if I move?
                        </button>
                    </h2>
                    <div id="afaq5" class="accordion-collapse collapse" data-bs-parent="#addressFaqAccordion">
                        <div class="accordion-body px-0 text-muted">
                            Add your new address using the form above. You can keep your old address for reference or delete it. Set the new address as default so future orders ship to the right place.
                        </div>
                    </div>
                </div>

            </div>

            <div class="text-center mt-5 pt-3">
                <h4 class="fw-bold mb-2">Need more help?</h4>
                <p class="text-muted mb-3">Reach out to our team.</p>
                <a href="/contact" class="btn btn-outline-dark rounded-pill px-4">Contact</a>
            </div>
        </div>
    </section>

    <!-- ========== FOOTER ========== -->
    <footer class="site-footer py-5" id="site-footer">
        <div class="container">
            <div class="footer-inner">
                <div class="row">
                    <div class="col-12 col-md-4 mb-4 mb-md-0">
                        <h6>Address</h6>
                        <p class="mb-3">Level 2, 45 King Street, Sydney NSW 2000</p>
                        <h6>Contact</h6>
                        <p class="mb-1"><a href="tel:18005550123">1800 555 0123</a></p>
                        <p><a href="mailto:hello@minimalistbookstore.com">hello@minimalistbookstore.com</a></p>
                        <div class="footer-social mt-3">
                            <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                            <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                            <a href="#" aria-label="Twitter X"><i class="bi bi-twitter-x"></i></a>
                            <a href="#" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                            <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 footer-links">
                        <a href="/products">All products</a>
                        <a href="/categories">Categories</a>
                        <a href="/contact">Contact us</a>
                        <a href="#">About us</a>
                        <a href="/account/orders">Order history</a>
                    </div>
                    <div class="col-6 col-md-4 footer-links">
                        <a href="/account/wishlist">Wishlist</a>
                        <a href="/account/profile">Account</a>
                        <a href="/cart">Cart</a>
                        <a href="/faq">FAQ</a>
                        <a href="/condition">Returns</a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom d-flex flex-column flex-sm-row justify-content-between align-items-center">
                <p class="mb-2 mb-sm-0">&copy; 2025 Minimalist Bookstore. All rights reserved.</p>
                <div class="d-flex gap-3">
                    <a href="#">Privacy policy</a>
                    <a href="#">Terms of service</a>
                    <a href="#">Cookie settings</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/cart.js"></script>
    <script src="/js/wishlist.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/account.js"></script>
</body>
</html>